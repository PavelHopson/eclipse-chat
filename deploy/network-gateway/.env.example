# Eclipse Network Gateway — copy to .env on the VPN/proxy host.

# Public DNS name or IPv4 of the host users connect to.
WG_SERVER_URL=vpn.example.com
WG_SERVER_PORT=51820

# Number or comma-separated peer names, e.g. pavel,laptop,phone.
WG_PEERS=pavel,laptop,phone

# Internal WireGuard subnet. Keep it separate from server LAN/VPC ranges.
WG_INTERNAL_SUBNET=10.66.0.0

# DNS pushed to VPN clients. Use your own resolver later if needed.
WG_PEER_DNS=1.1.1.1,9.9.9.9

# Container timezone.
TZ=Europe/Kaliningrad

# Closed HTTP/HTTPS proxy credentials.
# Generate with:
#   sudo apt-get install apache2-utils
#   htpasswd -nbB proxy-user 'strong-password'
# Put the full output into deploy/network-gateway/secrets/squid.htpasswd.
SQUID_HTTP_PORT=3128
