# PostgreSQL connection — с v0.6 ушли с SQLite, см. docs/DEVELOPMENT.md
#
# Pavel-specific: локальный PG 18 на машине разработки слушает на порту 5433.
# Если у тебя порт 5432 (стандартный) — поменяй ниже.
DATABASE_URL="postgresql://eclipse_chat_dev:dev_password@localhost:5433/eclipse_chat_dev?schema=public"
#
# DIRECT_URL обязательный (даже на native PG) — Prisma валидирует schema на
# наличие env. На native PG ставь тот же URL что DATABASE_URL.
# На Neon — раздели: DATABASE_URL = pooled, DIRECT_URL = direct (для migrate).
DIRECT_URL="postgresql://eclipse_chat_dev:dev_password@localhost:5433/eclipse_chat_dev?schema=public"
#
# Альтернатива — docker-compose.dev.yml (тоже порт 5433):
# DATABASE_URL="postgresql://eclipse_chat_dev:dev_password@localhost:5433/eclipse_chat_dev?schema=public"
# DIRECT_URL="postgresql://eclipse_chat_dev:dev_password@localhost:5433/eclipse_chat_dev?schema=public"

# Секрет подписи JWT. В проде — длинная случайная строка ≥32 символа.
# Если NODE_ENV=production и JWT_SECRET не задан — сервер не стартует.
JWT_SECRET="dev-secret-change-in-production"

# CORS для frontend (Vite dev на :5173). В проде — твой домен.
CORS_ORIGIN="http://localhost:5173"

# Порт Fastify + Socket.io. Если 3001 занят — поменяй здесь.
PORT=3001
