generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Пользователь — реальный человек. После v0.10 появится Bot, и Member
/// получит поле `type` (HUMAN | BOT) — но пока Member привязан только
/// к User.
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  displayName   String
  createdAt     DateTime       @default(now())

  messages      Message[]
  refreshTokens RefreshToken[]
  memberships   Member[]
  ownedServers  Server[]       @relation("ServerOwner")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Сервер — контейнер каналов и участников. Создатель автоматически
/// становится Member с role = "OWNER".
model Server {
  id          String   @id @default(cuid())
  name        String
  icon        String?
  /// Уникальный код для приёма по ссылке. Регенерируется через PATCH (TODO v0.4+).
  inviteCode  String   @unique @default(cuid())
  /// Владелец — User. Не может быть удалён пока ownsServer (onDelete: Restrict).
  ownerId     String
  owner       User     @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  channels    Channel[]
  members     Member[]
}

/// Участие пользователя в сервере. Один user — один Member per server.
///
/// `role` — строка, не enum: SQLite в Prisma не поддерживает enum нативно.
/// Допустимые значения проверяются в routes через zod:
///   "OWNER" | "ADMIN" | "MODERATOR" | "MEMBER"
/// В v0.6 при миграции на PostgreSQL → нативный enum MemberRole.
model Member {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  @@unique([userId, serverId])
}

/// Канал внутри сервера. serverId nullable в текущей версии — это
/// технический долг ради безопасной миграции существующих каналов
/// (см. ROADMAP § housekeeping). В v0.6 после PG-migration + backfill
/// — поднимем до NOT NULL.
model Channel {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  /// nullable temporarily — все новые каналы создаются с serverId.
  /// Legacy каналы без serverId после seed-миграции не существуют.
  serverId  String?
  server    Server?   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// Позиция в списке каналов сервера (для будущей сортировки UI).
  position  Int       @default(0)
  createdAt DateTime  @default(now())

  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}
