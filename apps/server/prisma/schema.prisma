generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl — для prisma migrate (он сам открывает несколько соединений
  // и не любит pgbouncer/pooler). Используется только во время migrate.
  // Для рантайма берётся `url` (= pooled DATABASE_URL).
  // На non-pooled провайдерах (локальный PG, Railway, etc) можно оставить
  // DIRECT_URL пустым в .env — Prisma fallback'нется на url.
  directUrl = env("DIRECT_URL")
}

/// Пользователь — реальный человек. После v0.10 появится Bot, и Member
/// получит поле `type` (HUMAN | BOT) — но пока Member привязан только
/// к User.
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  displayName   String
  /// URL аватара (path-based, обычно `/eclipse-chat/uploads/avatars/<file>`).
  /// nullable — при отсутствии UI рисует placeholder с инициалами.
  avatar        String?
  /// Краткое био пользователя — Twitter-like, max 280 символов
  /// (проверяется на уровне zod-валидации в роуте PATCH /api/users/me/profile).
  bio           String?
  /// Manual presence: ONLINE = default (auto), IDLE/DND/INVISIBLE — user
  /// override. Combines с auto-presence (socket-based) на render:
  /// если manual=INVISIBLE → frontend показывает offline; иначе manual
  /// overrides auto.
  status        UserStatus     @default(ONLINE)
  createdAt     DateTime       @default(now())
  /// 2FA TOTP secret (base32). Зашифрован при-rest через AES-256-GCM
  /// в app-layer (apps/server/src/auth/twoFactor.ts).
  twoFactorSecret      String?
  /// 2FA включён (secret сохранён И первый код подтверждён).
  twoFactorEnabled     Boolean   @default(false)
  /// Recovery codes — JSON массив bcrypt-хэшей. При verify сравниваем bcrypt
  /// и помечаем code как использованный (remove from list).
  twoFactorRecoveryCodes String?
  /// Счётчик неудачных попыток входа. Reset при успехе или после lockoutUntil.
  failedLoginAttempts  Int       @default(0)
  /// Времянка lockout после 5 неудачных попыток. Null = не залочен.
  lockoutUntil         DateTime?

  /// v1.2.6 Platform Admin (trek P1) — глобальный флаг владельца платформы
  /// (super-admin). Даёт доступ к /api/platform/* (списки всех users,
  /// бан/сброс пароля). Per-server роли (MemberRole) — отдельная иерархия;
  /// этот флаг с ними не связан.
  isPlatformOwner      Boolean   @default(false)
  /// v1.2.6 Platform Admin — когда user был забанен platform-owner'ом.
  /// NULL = активен. Banned user: login отклоняется, активные WS-сессии
  /// закрываются. Отличается от lockoutUntil (auto-brute-force lockout —
  /// временный, sec-based).
  bannedAt             DateTime?
  /// Причина бана (для аудита и UI). NULL когда не banned.
  bannedReason         String?
  /// FK на User, который применил бан. SetNull при удалении админа,
  /// чтобы запись о бане у юзера сохранилась даже если админ удалён.
  bannedByUserId       String?
  bannedBy             User?     @relation("UserBannedBy", fields: [bannedByUserId], references: [id], onDelete: SetNull)
  /// v1.2.7 Platform Admin (trek P2) — soft-delete. NULL = активен.
  /// При deletedAt !== null login/WS отклоняются, как у banned, но
  /// «навсегда». Данные пользователя (сообщения, задачи, комментарии)
  /// остаются в БД — UI рисует их как «удалённый пользователь».
  /// Обратимо вручную: UPDATE "User" SET "deletedAt"=NULL WHERE id=...
  deletedAt            DateTime?
  /// Причина удаления (для аудита и UI).
  deletedReason        String?
  /// FK на User, выполнившего удаление. SetNull при удалении админа.
  deletedByUserId      String?
  deletedBy            User?     @relation("UserDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  messages         Message[]
  refreshTokens    RefreshToken[]
  memberships      Member[]
  ownedServers     Server[]              @relation("ServerOwner")
  reactions        Reaction[]
  createdActionItems ActionItem[]        @relation("ActionItemCreator")
  assignedActionItems ActionItem[]       @relation("ActionItemAssignee")
  /// Items на которых я approver (v0.55). Pending → approver_userId = me.
  approvalQueue      ActionItem[]        @relation("ActionItemApprover")
  /// Operational Tables, созданные этим user'ом (v0.59 phase 1).
  createdTables      Table[]             @relation("TableCreator")
  /// v0.80 #26: Automation rules, созданные этим user'ом.
  createdAutomations AutomationRule[]    @relation("AutomationRuleCreator")
  /// v1.0.1: Composio app connections, созданные этим user'ом. Auto-set null
  /// при удалении user'а — connection остаётся, владельцем становится server OWNER.
  createdComposioConnections ComposioConnection[] @relation("ComposioConnectionCreator")
  /// Music sessions где user — host (v0.61). Один user может быть host'ом
  /// в нескольких channels одновременно.
  hostedMusicSessions MusicSession[]
  /// Comments написанные этим user'ом на ActionItem'ах (v0.54 drawer).
  actionItemComments ActionItemComment[]
  /// Audit-log записи где user был инициатором (v0.54). Null userId — system.
  actionItemActivities ActionItemActivity[]
  /// DM conversations где user — userA (нормализованная позиция, см. DirectConversation).
  /// Для group DMs userA/userB NULL — membership через ConversationParticipant.
  dmsAsUserA       DirectConversation[]  @relation("DMUserA")
  /// DM conversations где user — userB.
  dmsAsUserB       DirectConversation[]  @relation("DMUserB")
  /// Group DMs, созданные этим user'ом (host). Legacy 1-to-1 имеют createdByUserId=NULL.
  dmGroupsCreated  DirectConversation[]  @relation("DMCreator")
  /// Участие в group DMs (новая модель v0.52). 1-to-1 DMs используют userA/userB,
  /// group DMs — этот join. Membership-check унифицирован в route helper.
  dmParticipations ConversationParticipant[]
  auditLogs        AuditLog[]
  /// v1.2.6 Platform Admin — users, которых ЭТОТ user (platform-owner) забанил.
  /// Reverse-side bannedBy self-relation.
  bannedUsers      User[]                @relation("UserBannedBy")
  /// v1.2.7 Platform Admin (trek P2) — users, soft-deleted этим admin'ом.
  deletedUsers     User[]                @relation("UserDeletedBy")
  /// v1.2.7 Platform Admin (trek P2) — servers, которые этот platform-owner
  /// suspend'нул. Reverse-side ServerSuspendedBy self-relation.
  suspendedServers Server[]              @relation("ServerSuspendedBy")
  /// Боты которыми владеет user (как создатель).
  ownedBots        Bot[]                 @relation("BotOwner")
  /// Если user — это shadow user для bot'а (1-to-1). null = обычный User.
  botProfile       Bot?                  @relation("BotShadowUser")
  /// Инциденты открытые этим user'ом.
  openedIncidents  Incident[]            @relation("IncidentOpener")
  /// Last-visit per channel (AI Memory «Since your last visit»).
  channelVisits    ChannelLastVisit[]
  /// v0.84 #27 phase 3: web-push subscriptions (per-device). При удалении user'а
  /// все его pushSubscriptions удаляются cascade (включая ключи), чтобы не
  /// слать notifications мёртвому user'у.
  pushSubscriptions PushSubscription[]
  /// v0.85 #27 phase 4: per-event-type push preferences. 1-to-1, lazy-created
  /// при первом explicit toggle в UI. Отсутствие row = все типы enabled (default).
  notificationPreferences NotificationPreferences?
  /// v0.85 #27 phase 4: каналы которые user заглушил (push skip).
  mutedChannels MutedChannel[]
  /// v0.86 #24 phase 2: счета, которые этот user создал (SetNull при удалении).
  createdInvoices Invoice[]
  /// v0.88 #23 phase 1: voice notes последняя редактура которых от меня.
  editedVoiceNotes VoiceNote[]
  /// v0.89 #26 phase 2: интеграции, которые этот user настроил.
  createdIntegrations Integration[]
  /// v1.2.20: custom-emoji, загруженные этим user'ом. SetNull при
  /// удалении user'а — emoji остаётся на сервере, владельцем становится
  /// «—».
  uploadedEmojis      Emoji[]
  /// v1.5.42 Discord-parity A1: friendships где user — userA (нормализованная
  /// позиция, см. Friendship.userAId < userBId). Покрывает и PENDING/ACCEPTED/
  /// BLOCKED — фильтрация по status в роутах.
  friendshipsAsUserA  Friendship[] @relation("FriendshipUserA")
  /// v1.5.42 Discord-parity A1: friendships где user — userB.
  friendshipsAsUserB  Friendship[] @relation("FriendshipUserB")
  /// v1.5.42 Discord-parity A1: friend requests, инициированные этим user'ом.
  /// SetNull при удалении user'а — friendship остаётся между остальными
  /// сторонами (BLOCKED не теряем). На практике обе стороны cascade-delete'нутся
  /// через userA/userB FK раньше — это relation для completeness Prisma client'а.
  friendRequestsSent  Friendship[] @relation("FriendshipRequestedBy")
  /// v1.5.42 Discord-parity A1: friendships которые этот user заблокировал.
  /// Опять SetNull для completeness; cascade-delete срабатывает раньше.
  friendshipsBlockedBy Friendship[] @relation("FriendshipBlockedBy")
}

/// v0.85 #27 phase 4: per-event-type notification toggles.
///
/// Хранится как один row per user с булевыми флагами. Default — все true
/// (отсутствие row = всё enabled, чтобы не нужен был bulk-seed при upgrade).
/// Каждое поле = один event type, который может trigger'ить push:
///   mentions     — @<displayName> в TEXT/EXECUTION каналах
///   dms          — сообщения в DM (1-to-1 + groups)
///   assignments  — мне назначили ActionItem
///   approvals    — запрос approval на ActionItem где я approver
///   escalations  — overdue 48h+ на моей задаче
///
/// Phase 5 — per-channel mute (already separate model). Phase 6 — quiet hours.
model NotificationPreferences {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentions     Boolean  @default(true)
  dms          Boolean  @default(true)
  assignments  Boolean  @default(true)
  approvals    Boolean  @default(true)
  escalations  Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

/// v0.85 #27 phase 4: каналы которые user заглушил. Push в эти каналы skip'ается
/// независимо от event-type toggle. UI — context-menu на канале «Заглушить».
///
/// Composite PK (userId, channelId) — один user заглушает один канал максимум
/// один раз. Cascade на обе стороны — удаление user'а или канала очищает.
model MutedChannel {
  userId    String
  channelId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  mutedAt   DateTime @default(now())

  @@id([userId, channelId])
  @@index([channelId])
}

/// v0.84 #27 phase 3: Web Push API subscription (per-device).
///
/// Один user может иметь несколько subscriptions — по одной на каждый browser
/// session где он включил push. `endpoint` глобально уникален (URL push-сервиса
/// браузера). При expiration (HTTP 410 от push-сервиса) row удаляется cleanup'ом
/// в `notifyUser()` helper'е.
///
/// Storage: p256dh + auth — base64url-encoded ключи от browser
/// `PushSubscription.toJSON()`. userAgent сохраняется для UI «удалить с этого
/// устройства». lastSeenAt бампится при каждой successful send'и.
///
/// Privacy: payload через web-push API шифруется browser-public-key + auth —
/// content виден только подписавшемуся user'у (не push-сервису).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// URL push-сервиса браузера (Mozilla / Google FCM / Apple). Unique.
  endpoint  String   @unique
  /// Browser public key (ECDH p256). Base64url.
  p256dh    String
  /// Auth secret для AES-GCM. Base64url.
  auth      String
  /// User-Agent string на момент subscribe. Для UI «удалить с этого устройства».
  userAgent String?
  createdAt DateTime @default(now())
  /// Бампится при каждой successful push send. Используется для cleanup'а
  /// stale subs (older than 30 дней без активности — кандидаты на удаление).
  lastSeenAt DateTime @default(now())

  @@index([userId])
}

/**
 * Bot — operator entity внутри сервера. main differentiator Eclipse Chat
 * от Discord: bots = first-class citizens с явным API контрактом,
 * не webhooks-only.
 *
 * Архитектурное решение — bot реиспользует существующую User модель как
 * «shadow user»:
 *   - При create Bot — создаётся User row с email `bot-<botId>@eclipse-chat.local`.
 *   - Bot.userId → User.id (1-to-1).
 *   - Messages from bot выглядят как обычные Message с user.id = bot's shadow user.
 *   - Member.userId работает для bot'а как для регулярного юзера (auto-добавляется
 *     в server при create).
 * Это упрощает Message.userId, Reaction, Avatar и т.д. — никакой polymorphism.
 *
 * API auth:
 *   Authorization: Bot ecb_<32-char-base64>
 *   - Сравнение через bcrypt(apiKey, apiKeyHash).
 *   - apiKeyPrefix хранится для quick row-lookup (первые 12 символов).
 */
model Bot {
  id           String   @id @default(cuid())
  name         String
  /// Avatar URL — может быть кастомным или auto-generated.
  avatar       String?
  /// Описание роли бота (для UI), до 280 символов.
  description  String?
  /// Bcrypt hash of API key. Plaintext возвращается одноразово при create/regen.
  apiKeyHash   String
  /// Префикс API key для quick lookup (`ecb_` + 8 chars). Unique для O(1) find.
  apiKeyPrefix String   @unique
  /// Server в котором bot живёт (scoped к одному, как Discord webhooks).
  serverId     String
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// Owner user — может regenerate key и delete bot. Cascade при удалении user'а
  /// удаляет bots — admin должен передать ownership перед уходом из server'а.
  ownerUserId  String
  owner        User     @relation("BotOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  /// Shadow user (1-to-1). Auto-created при bot creation. Bot posts messages
  /// как этот user; reactions, mentions работают штатно.
  userId       String   @unique
  user         User     @relation("BotShadowUser", fields: [userId], references: [id], onDelete: Cascade)
  /// Роль бота — определяет system-prompt template, UI badge и (в будущем)
  /// поведение AI invocation. Default GENERIC = существующие боты не ломаются.
  role         BotRole  @default(GENERIC)
  /// Отвечать на каждое сообщение в TEXT-каналах сервера (без @mention).
  /// Если несколько ботов с autoRespond — отвечает oldest createdAt.
  autoRespond  Boolean  @default(false)
  /// Кастомный system prompt (приоритет над role-template). Max 8000 в API.
  systemPromptOverride String?
  /// v1.2.27 — Personality / character overlay (до 1000 символов). В
  /// отличие от systemPromptOverride, это short tone/humor описание
  /// которое **дописывается** к role-prompt'у (а не заменяет). Цель:
  /// чтобы admin/MOD мог дать боту «характер» (имя «Алёша», шутит про
  /// senior dev'ов, любит уличный сленг) без переписывания всего
  /// system prompt'а. Применяется только когда systemPromptOverride
  /// пустой — full override остаётся advanced-режимом.
  personality          String?
  /// JSON array capabilities: ["send_message", "create_action_item", "react"].
  /// Сейчас всё разрешено — но field готов под granular ACL в v0.12.1.
  capabilities String   @default("[\"send_message\",\"react\"]")
  /// HTTPS URL для outbound webhook'ов. Backend POST'ит сюда события
  /// (message.created etc) от каналов где bot — member. Null = нет webhook.
  webhookUrl    String?
  /// Shared secret для HMAC-SHA256 signing webhook payloads. Если задан —
  /// header X-Eclipse-Bot-Signature: sha256=<hex> добавляется на каждый POST.
  webhookSecret String?
  /// JSON массив subscribed events. Default ["message.created"]. Bot
  /// получает только events что в списке.
  webhookEvents String   @default("[\"message.created\"]")
  createdAt    DateTime @default(now())
  /// Когда bot последний раз был использован (любой successful API call).
  lastUsedAt   DateTime?

  @@index([serverId])
  @@index([ownerUserId])
}

/**
 * Audit log: журнал security-events и admin-действий.
 * Никогда не удаляем (compliance). Старше 1 года будут архивироваться
 * cron'ом в отдельную таблицу (v1.x).
 */
enum AuditEventType {
  AUTH_LOGIN
  AUTH_LOGIN_FAILED
  AUTH_LOGIN_LOCKED
  AUTH_LOGOUT
  AUTH_REGISTER
  AUTH_PASSWORD_CHANGE
  TWOFA_ENABLED
  TWOFA_DISABLED
  TWOFA_VERIFIED
  TWOFA_RECOVERY_USED
  SERVER_CREATED
  SERVER_DELETED
  SERVER_BANNER_CHANGED
  SERVER_IDENTITY_CHANGED
  MEMBER_ROLE_CHANGED
  MEMBER_KICKED
  MESSAGE_DELETED_BY_MOD
  CHANNEL_CREATED
  CHANNEL_DELETED
  BOT_CREATED
  BOT_DELETED
  BOT_KEY_REGENERATED
  /// v1.0 #11 AI controls: prompt overrides + test invocation observability.
  BOT_PROMPT_UPDATE
  BOT_PROMPT_RESET
  BOT_TEST_INVOKE
  /// v1.0.1 Composio integration: OAuth-managed external apps.
  COMPOSIO_CONNECTED
  COMPOSIO_DISCONNECTED
  COMPOSIO_ACTION_EXECUTED
  /// v1.2.6 Platform Admin (trek P1) — глобальные администраторские
  /// действия super-admin'а. metadata: { targetUserId, reason? }.
  PLATFORM_USER_BANNED
  PLATFORM_USER_UNBANNED
  PLATFORM_USER_PASSWORD_RESET
  /// v1.2.7 Platform Admin (trek P2) — расширение: soft-delete + сервера.
  PLATFORM_USER_DELETED
  PLATFORM_SERVER_SUSPENDED
  PLATFORM_SERVER_UNSUSPENDED
}

model AuditLog {
  id        String         @id @default(cuid())
  type      AuditEventType
  /// User инициатор (может быть null для system events / failed login attempts).
  userId    String?
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// IP origin (для security-расследований). Best-effort, может быть proxy IP.
  ipAddress String?
  /// User-Agent string для browser fingerprint.
  userAgent String?
  /// Дополнительные metadata в JSON (target serverId, что менялось etc).
  /// Никаких PII — только id'шники и status flags.
  metadata  String?
  createdAt DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Роли участников. PostgreSQL поддерживает enum нативно — после v0.6
/// миграции с SQLite на PG используем enum вместо String.
///
/// v0.78 #17 phase 1: расширение taxonomy с 4 ролей до 10. Новые роли —
/// hierarchical operational identity, не permission-overrides. Permission
/// matrix (hasPermission helper) определяет capabilities каждой роли.
/// Phase 2 — full RBAC с custom roles per workspace.
enum MemberRole {
  OWNER
  ADMIN
  MODERATOR
  /// v0.78 #17: tech-lead / architecture decisions. Read all, edit specs.
  ARCHITECT
  /// v0.78 #17: engineer / contributor. Создаёт каналы и задачи.
  DEVELOPER
  /// v0.78 #17: execution / dispatch. Triage задач, assignments, approvals.
  OPERATOR
  /// v0.78 #17: external client (in CLIENT-mode workspace). Read + comment
  /// в non-internal channels.
  CLIENT
  /// v0.78 #17: read-only с analytics-доступом (reviewer, stakeholder).
  VIEWER
  /// v0.78 #17: limited TEXT-only без analytics. Для temporary вход.
  GUEST
  MEMBER
}

/// Тип канала. TEXT — обычный чат. VOICE — голосовой канал (LiveKit).
/// BROADCAST — канал-вещание (news/blogger, Discord×Telegram-гибрид):
/// читают все участники, публикуют только OWNER/ADMIN/MODERATOR.
/// POST messages блокируется для VOICE; для BROADCAST — gated по роли.
enum ChannelType {
  TEXT
  VOICE
  BROADCAST
  /// v0.74 #16 phase 1: execution-комната. Чат заменяется на встроенный
  /// channel-scoped StatusBoard kanban (filter actions по channelId).
  /// Сообщения всё ещё пишутся (вне kanban — могут идти как "обсуждение"),
  /// но primary view — Status Board, не feed.
  EXECUTION
}

/// Manual presence status — user-controlled. ONLINE = default (auto от
/// socket connection). IDLE/DND — user не доступен, но видим как member.
/// INVISIBLE = appears offline для других (но socket connection живой).
enum UserStatus {
  ONLINE
  IDLE
  DND
  INVISIBLE
}

enum ActionItemType {
  TASK
  DECISION
  FOLLOW_UP
}

/// Режим сервера — Client Portal vs Engineering / Internal Ops.
/// CLIENT: мягче UI, скрыты operator-инструменты (Status Board / Execution tab
/// / slash-command hints / BOT badges) — клиент видит calm room, не developer
/// chrome. ENGINEERING (default): полный operator-set.
enum ServerMode {
  ENGINEERING
  CLIENT
}

/// Типология ботов — превращает их из generic shadow-users в embedded
/// role-aware participants. Каждая роль имеет свой system-prompt template
/// (см. ai/botRoles.ts) и собственный визуальный label/colour.
///
///   GENERIC   — default, без специализации (Telegram bridge, мониторинг и т.п.)
///   MODERATOR — channel watchdog: этикет, warning, cleanup-suggestions
///   PM        — project management: задачи / решения / follow-up reminders
///   KNOWLEDGE — server knowledge assistant: Q&A над pinned + history
///   SALES     — outreach / клиентские диалоги (нужно подавать tone)
enum BotRole {
  GENERIC
  MODERATOR
  PM
  KNOWLEDGE
  SALES
  /// v0.74 #18 phase 1: helpdesk-агент. @support / @поддержка mention.
  SUPPORT
  /// v0.74 #18 phase 1: architecture/tech-summaries. @architect / @архитектор.
  ARCHITECT
}

/// Статус инцидента. OPEN = разбор идёт, RESOLVED = закрыт + post-mortem сгенерён.
enum IncidentStatus {
  OPEN
  RESOLVED
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  REVIEW
  DONE
}

/// Приоритет action item. Default NORMAL — backward-compat для existing
/// rows. UI рендерит цветной badge: LOW=idle, NORMAL=text-muted,
/// HIGH=warn, URGENT=risk.
enum ActionItemPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// Audit-log тип события для ActionItemActivity. Расширяется по мере
/// добавления новых mutable полей.
enum ActionItemActivityType {
  CREATED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  DUE_CHANGED
  PRIORITY_CHANGED
  TITLE_CHANGED
  DESCRIPTION_CHANGED
  COMMENT_ADDED
  COMMENT_DELETED
  APPROVAL_REQUESTED
  APPROVAL_APPROVED
  APPROVAL_REJECTED
  DEPENDENCY_ADDED
  DEPENDENCY_REMOVED
  ESCALATED
  AI_SUMMARY_GENERATED
}

/// Статус одобрения action item (v0.55). Отдельный axis от ActionItemStatus —
/// item может быть DONE и не требовать approval, или OPEN и быть APPROVED.
/// Lifecycle: NONE → PENDING → APPROVED / REJECTED. Только approver может
/// перевести из PENDING в финальное состояние.
enum ApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

/// Статус транскрипции аудио-вложения (v0.58). NONE = не запускали (non-audio
/// файл или OPENAI_API_KEY не сетап); PENDING = в работе fire-and-forget;
/// READY = transcript заполнен; FAILED = transcript ошибка (error в
/// transcriptError). UI рендерит status под audio-player.
enum TranscriptStatus {
  NONE
  PENDING
  READY
  FAILED
}

/// Тип поля Operational Table (v0.59 phase 1, расширено v0.62 phase 2).
/// Phase 2 добавил USER (cell.value = userId, UI рендерит avatar/name из
/// member list) и CHECKBOX (cell.value = "true"|"false"). Phase 2.5+ —
/// RELATION (cross-table), FILE (attachment), FORMULA. Coercion value
/// хранится как строка, frontend приводит к нужному типу при render/edit.
enum TableFieldType {
  TEXT
  NUMBER
  STATUS
  DATE
  USER
  CHECKBOX
  /// v0.75 #10 phase 2.5b: ссылка на row(ы) другой таблицы того же сервера.
  /// Cell.value = JSON array of rowIds. Field.linkedTableId — target table.
  RELATION
  /// v0.75 #10 phase 2.5b: файлы в ячейке (upload via /api/tables/:id/upload).
  /// Cell.value = JSON array of `{url, filename, mimeType, size}` objects.
  FILE
}

/// Сервер — контейнер каналов и участников. Создатель автоматически
/// становится Member с role = OWNER.
model Server {
  id          String   @id @default(cuid())
  name        String
  icon        String?
  /// Banner image, 1500×500 webp (resized sharp). Хедер чата + сервер-инфо.
  banner      String?
  /// HSL brand color string без `hsl()` wrapper: "200 80% 60%". Frontend
  /// инжектит `:root { --ec-accent: hsl(X) }` пока активен этот сервер.
  /// Null = default cool sky. Per-server theming без full redesign.
  brandColor  String?
  /// Markdown-описание сервера (до 1000 символов). Показывается в Info modal
  /// и welcome screen для новых членов.
  description String?
  /// Welcome-сообщение для новых members. Показывается один раз в первом
  /// TEXT канале как dismissible system-card. До 500 символов.
  welcomeMessage String?
  /// Режим сервера. ENGINEERING (default) = полный operator-инструментарий.
  /// CLIENT = мягче UI, скрыты Status Board / Execution / slash hints —
  /// для портала клиентов агентств / dev-студий / консалтинга. Меняется
  /// OWNER'ом в Server Settings.
  mode        ServerMode @default(ENGINEERING)
  /// Уникальный код для приёма по ссылке. Регенерируется через PATCH (TODO v0.4+).
  inviteCode  String   @unique @default(cuid())
  /// Владелец — User. Не может быть удалён пока ownsServer (onDelete: Restrict).
  ownerId     String
  owner       User     @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  /// v1.2.7 Platform Admin (trek P2) — server suspend (заморозка).
  /// При suspendedAt !== null write-операции (постинг, создание каналов,
  /// изменение settings, создание задач) блокируются на уровне роутов
  /// через assertServerActive(). Чтение остаётся (история не пропадает).
  /// Обратимо через /api/platform/servers/:id/unsuspend.
  suspendedAt       DateTime?
  suspendedReason   String?
  suspendedByUserId String?
  suspendedBy       User?    @relation("ServerSuspendedBy", fields: [suspendedByUserId], references: [id], onDelete: SetNull)

  channels    Channel[]
  members     Member[]
  actionItems ActionItem[]
  bots        Bot[]
  incidents   Incident[]
  tables      Table[]
  /// v0.80 #26 phase 1: automation rules (trigger + action декларативные).
  automations AutomationRule[]
  /// v0.86 #24 phase 2: client invoices (server-scoped).
  invoices    Invoice[]
  /// v0.89 #26 phase 2: external integrations (Telegram outgoing, GitHub
  /// incoming webhook). Cascade при удалении server'а.
  integrations Integration[]
  /// v1.0.1 #11.5 Composio integration: per-server OAuth-managed apps
  /// (500+ через единый Composio proxy). Cascade при удалении server'а.
  composioConnections ComposioConnection[]
  /// v1.2.20: custom-emoji per-server. Cascade при удалении server'а.
  emojis              Emoji[]
}

/// v0.80 #26 phase 1: Automation system — declarative trigger/action правила
/// для workspace. Phase 1 поддерживает один trigger-type (MESSAGE_NEW) и
/// один action-type (POST_MESSAGE) — это покрывает 80% use-cases типа
/// «когда кто-то пишет X в #общий → бот публикует Y в #команда».
///
/// Storage: trigger + action как JSON-string (Postgres TEXT) — даёт
/// гибкость без новых tables на каждый тип. Phase 2 — schema'у можно
/// расширять разными trigger/action types (FILE_UPLOAD, NEW_TASK,
/// APPROVAL, и т.п.), Bot Builder visual editor.
///
/// Evaluation: при создании message в channel — async fire-and-forget
/// сканирует enabled rules сервера, matches keyword/channel filter,
/// fires action (например, posts message от system bot в target channel).
/// `lastFiredAt` + `fireCount` для UI «правило сработало N раз».
model AutomationRule {
  id              String   @id @default(cuid())
  serverId        String
  server          Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name            String
  enabled         Boolean  @default(true)
  /// JSON: { type: "MESSAGE_NEW", keyword?: string, channelId?: string, caseInsensitive?: bool }
  trigger         String
  /// JSON: { type: "POST_MESSAGE", channelId: string, template: string }
  action          String
  createdByUserId String?
  createdBy       User?    @relation("AutomationRuleCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  /// Timestamp последнего срабатывания (для UI «работало N часов назад»).
  lastFiredAt     DateTime?
  /// Cum. счётчик срабатываний (для UI). Increment на каждый fire.
  fireCount       Int      @default(0)

  @@index([serverId, enabled])
}

/**
 * Incident — операторский «контур разбора». Создаётся кнопкой «Открыть
 * инцидент»: спавнит dedicated TEXT-канал, собирает timeline (ActionItems
 * + pinned messages), при resolve генерит post-mortem через Ollama.
 *
 * Главный differentiator Eclipse Chat как operator console — связывает
 * уже построенные слои (channels + ActionItems + AI) в incident workflow.
 */
model Incident {
  id             String         @id @default(cuid())
  serverId       String
  server         Server         @relation(fields: [serverId], references: [id], onDelete: Cascade)
  title          String
  status         IncidentStatus @default(OPEN)
  /// Dedicated channel инцидента. SET NULL если канал удалён руками —
  /// Incident-запись остаётся для history. 1-to-1 с Channel.incidentId.
  channelId      String?        @unique
  channel        Channel?       @relation("IncidentChannel", fields: [channelId], references: [id], onDelete: SetNull)
  openedByUserId String
  openedBy       User           @relation("IncidentOpener", fields: [openedByUserId], references: [id], onDelete: Restrict)
  openedAt       DateTime       @default(now())
  resolvedAt     DateTime?
  /// Post-mortem markdown. Генерится Ollama при resolve. Null пока OPEN.
  postMortem     String?

  @@index([serverId, status])
  @@index([channelId])
}

/// Участие пользователя в сервере. Один user — один Member per server.
model Member {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId  String
  server    Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  role      MemberRole @default(MEMBER)
  joinedAt  DateTime   @default(now())

  @@unique([userId, serverId])
}

/// Канал внутри сервера. После миграции на PG поле serverId стало
/// обязательным (NOT NULL) — backfill сделан в v0.4 seed, technical
/// debt из ROADMAP §housekeeping закрыт.
model Channel {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  serverId  String
  server    Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// Тип канала. По умолчанию TEXT — обратная совместимость с v0.4.
  type      ChannelType @default(TEXT)
  /// Позиция в списке каналов сервера (для будущей сортировки UI).
  position  Int         @default(0)
  /// Описание канала (до 1024 символов). Показывается в chat header
  /// под #channel-name + в ChannelSettingsModal. Nullable = нет описания.
  description String?
  /// Кастомный emoji prefix вместо # (TEXT) / 🔊 (VOICE) в UI.
  /// Single emoji char, может быть compound (👨‍💻). Null = default glyph.
  emoji       String?
  /// v0.47 Client Mode v2: internal-канал виден ТОЛЬКО OWNER/ADMIN/MODERATOR
  /// когда Server.mode = CLIENT. В ENGINEERING serverе flag ignored (все
  /// каналы видны всем members). Channel rename/delete не зависят от flag.
  internal    Boolean    @default(false)
  /// v0.74 #29 phase 1: temporary rooms. Если задано — канал авто-удаляется
  /// cron'ом после `expiresAt`. UI показывает countdown badge в chat-header.
  /// NULL = постоянный канал. Hard delete (cascade messages/actions).
  expiresAt   DateTime?
  /// Если канал — incident-канал, ссылка на Incident. Unique (1-to-1).
  /// Null для обычных каналов. UI рисует incident badge если set.
  incidentId  String?    @unique
  incident    Incident?  @relation("IncidentChannel")
  createdAt DateTime    @default(now())

  messages  Message[]
  actionItems ActionItem[]
  visits    ChannelLastVisit[]
  tables    Table[]
  musicSession MusicSession?
  /// v0.85 #27 phase 4: inverse relation для MutedChannel.
  mutedBy   MutedChannel[]
  /// v0.88 #23 phase 1: shared voice-room notepad (Yjs CRDT).
  voiceNote VoiceNote?

  @@index([expiresAt])
}

/// v0.89 #26 phase 2: тип внешней интеграции.
///
///   TELEGRAM_OUTGOING — Eclipse Chat → Telegram chat (post on message:new
///                       в bridged Eclipse channel).
///   GITHUB_WEBHOOK    — GitHub → Eclipse (receive PR/issue/push events,
///                       post в bridged channel как system bot).
///
/// Phase 2b: TELEGRAM_INCOMING (TG → Eclipse), NOTION_SYNC (2-way).
enum IntegrationType {
  TELEGRAM_OUTGOING
  GITHUB_WEBHOOK
}

/// v0.89 #26 phase 2: external integration per server.
///
/// `config` — JSON-encoded plaintext, encrypted на rest через
/// `encryptSecret`/`decryptSecret` (AES-256-GCM, reuses TWOFA_ENCRYPTION_KEY).
/// Shape зависит от `type`:
///   - TELEGRAM_OUTGOING: `{ "botToken": "...", "chatId": "-100..." }`
///   - GITHUB_WEBHOOK:    `{}` (secret в `webhookSecret` plaintext, path в `webhookPath`).
///
/// `channelId` — для TELEGRAM_OUTGOING это source channel (Eclipse → TG),
/// для GITHUB_WEBHOOK это target channel (GH → Eclipse).
///
/// `webhookPath` — random unique slug для public webhook URL.
/// `webhookSecret` — HMAC-SHA256 secret для verify request signature.
///
/// Permissions: OWNER/ADMIN only create/edit/delete. View — все members
/// (для transparency что bridged).
model Integration {
  id              String          @id @default(cuid())
  serverId        String
  server          Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type            IntegrationType
  name            String
  /// Encrypted JSON config (AES-256-GCM). Plaintext shape — см. enum docs.
  config          String
  /// Source/target channel (см. type docs).
  channelId       String?
  /// Random unique slug для webhook URL (только GITHUB_WEBHOOK).
  webhookPath     String?         @unique
  /// HMAC secret (только GITHUB_WEBHOOK). Plaintext — used for signature
  /// verify. Не leak через API (returned `null` в read responses).
  webhookSecret   String?
  enabled         Boolean         @default(true)
  createdByUserId String?
  createdBy       User?           @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  /// Timestamp последнего successful event (outgoing fire или incoming receive).
  lastEventAt     DateTime?
  /// Cumulative event counter (для UI «сработало N раз»).
  eventCount      Int             @default(0)

  @@index([serverId, enabled])
  @@index([type])
}

/// v1.0.1 #11.5: Composio integration — per-server OAuth-managed external
/// app connection. Composio acts as proxy к 500+ apps (Gmail / Slack / Notion /
/// Jira / Asana / Airtable / Twilio / etc) с unified action-execute API.
///
/// Eclipse Chat хранит:
///   - `composioConnId` — Composio-side connection ID (returned после OAuth completion)
///   - `encryptedAuth` — AES-256-GCM encrypted JSON с access/refresh tokens
///     если Composio отдаёт их клиенту (некоторые apps — opaque на стороне Composio)
///   - `appName` — slug app'а ("gmail", "slack", "notion") — unique per server
///   - `status` — ACTIVE / EXPIRED / DISCONNECTED (string для будущей extensibility)
///
/// Usage:
///   1. OWNER инициирует connect через UI → backend вызывает Composio's
///      `initiate_connection` endpoint → returns auth URL → user redirected
///   2. После OAuth user redirected обратно (callback handler validates +
///      stores connectionId)
///   3. Automation rules с COMPOSIO_ACTION действиями reference connectionId +
///      actionName + params template
///
/// Encryption: encryptedAuth опционален — некоторые apps в Composio
/// keep tokens server-side, мы храним только connectionId. Если Composio
/// возвращает tokens — encrypt с TWOFA_ENCRYPTION_KEY как для Integration.config.
model ComposioConnection {
  id              String   @id @default(cuid())
  serverId        String
  server          Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// App slug в Composio ("gmail", "slack", "notion", etc).
  appName         String
  /// User-friendly display name ("Gmail для команды Marketing").
  displayName     String
  /// Composio's connection identifier (returned после OAuth).
  composioConnId  String
  /// AES-256-GCM encrypted JSON с client-side tokens (если есть).
  /// Пустая string = tokens хранятся на стороне Composio.
  encryptedAuth   String
  /// ACTIVE / EXPIRED / DISCONNECTED. String для будущей extensibility.
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdBy       User?    @relation("ComposioConnectionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  lastUsedAt      DateTime?

  @@index([serverId])
  @@unique([serverId, appName])
}

/// v0.88 #23 phase 1a: shared notepad attached to a VOICE channel.
///
/// Один doc per channel (1-to-1, channelId UNIQUE). Phase 1a — plain
/// shared text с last-writer-wins (no CRDT). Phase 1b — upgrade на Yjs
/// binary state когда yjs npm install отработает (today registry rejects).
///
/// Persistence model (phase 1a):
///   - `content` — plain UTF-8 text (markdown). String — phase 1b
///     переключится на Bytes для Yjs binary.
///   - `version` increments на каждый PATCH. UI optimistic — посылает
///     `baseVersion`, сервер accept'ит если совпадает; иначе returns 409
///     с current state для merge.
///   - Update broadcast'ится через `voice-note:updated` socket event
///     в `channel:${id}` room.
///
/// channelId Cascade: при удалении канала doc auto-cleanup. lastEditorUserId
/// SetNull — preserve doc после удаления автора (cascade policy B).
model VoiceNote {
  id                String   @id @default(cuid())
  channelId         String   @unique
  channel           Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  /// Plain text content. Phase 1a — markdown без CRDT. Phase 1b — Yjs
  /// binary state (мигрируем тип на Bytes).
  content           String   @default("")
  /// Optimistic concurrency. Bumped на каждый successful save.
  version           Int      @default(0)
  lastEditorUserId  String?
  lastEditor        User?    @relation(fields: [lastEditorUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([channelId])
}

/// Сообщение. Может принадлежать ЛИБО серверному каналу (`channelId`),
/// ЛИБО direct-conversation (`conversationId`) — XOR-инвариант
/// проверяется на уровне route'ов (Prisma не имеет check constraints).
/// Из двух полей всегда заполнено ровно одно.
model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  /// Время последнего edit'а. Null = не редактировалось.
  editedAt  DateTime?
  /// Soft-delete: deletedAt set → content скрывается, replaced placeholder'ом
  /// в UI. Row остаётся для thread/reply контекста (v0.12).
  deletedAt DateTime?
  /// Pin-bar в chat-header показывает все messages где pinnedAt != null,
  /// sort by pinnedAt desc. Pin/unpin доступен OWNER/ADMIN/MODERATOR.
  /// Для DM messages pin не разрешён (нет ролей в DM).
  pinnedAt  DateTime?
  /// v0.63 cascade policy B: nullable + SetNull. При удалении User
  /// message остаётся, автор=null, UI рендерит «Удалённый пользователь».
  /// Bot deletions / GDPR-style erasure теперь не уничтожают историю.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Канал в server-context. NULL → message принадлежит DM-разговору.
  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  /// DM-разговор. NULL → message принадлежит серверному каналу.
  conversationId String?
  conversation   DirectConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// Thread self-relation: root-сообщения имеют parentMessageId=NULL.
  /// Replies — id root'а. onDelete:SetNull = при удалении root replies остаются
  /// orphan (history preserved, UI рендерит placeholder).
  parentMessageId String?
  parent          Message?  @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  threadReplies   Message[] @relation("MessageThread")
  reactions Reaction[]
  attachments Attachment[]
  actionItems ActionItem[]
  /// v0.77 #21: AI memory + semantic search. Inverse relation для cascade.
  embedding   MessageEmbedding?
  /// v1.5.24 — edit history. Snapshot previous content на каждый edit.
  edits     MessageEdit[]

  @@index([channelId, pinnedAt])
  @@index([conversationId, createdAt])
  @@index([parentMessageId])
}

/// v1.5.24 — История редактирования сообщений. На каждый PATCH /api/messages/:id
/// (или DM-equivalent) backend сохраняет previous content + previous editedAt
/// перед перезаписью. Frontend показывает history по клику на «(изменено)» tag.
/// Cascade-delete при удалении message — history исчезает вместе с ним.
model MessageEdit {
  id            String   @id @default(cuid())
  messageId     String
  message       Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  /// Content на момент edit'а (то что user видел до этого правки).
  /// Текущий content всегда в Message.content; здесь — снапшоты прошлого.
  previousContent String
  /// Когда был сделан edit, который ПОРОДИЛ этот snapshot.
  /// (Т.е. when current Message.content стал новым.)
  editedAt      DateTime @default(now())

  @@index([messageId, editedAt])
}

/// v0.77 #21 phase 1: embedding для семантического поиска.
///
/// Один embedding per message (unique). Vector storage — `Float[]` без
/// pgvector dependency (анти-pattern на native PG где extension может
/// быть не установлен). Cosine similarity вычисляется в Node при поиске.
/// Performance trade-off: для <30K messages OK, > → future миграция на
/// pgvector + IVFFlat index.
///
/// Vectors normalized на write (unit-length) — search = простой dot-product.
/// Model column фиксирует какой embedder использовался — позволяет
/// re-embed batch'ем при смене модели.
model MessageEmbedding {
  id        String   @id @default(cuid())
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  /// Unit-normalized vector (cosine via dot-product). Ожидаемая длина 768
  /// для nomic-embed-text / text-embedding-3-small (с dimensions=768).
  vector    Float[]
  /// Embedder identifier — `ollama:nomic-embed-text` / `openai:text-embedding-3-small`.
  model     String
  createdAt DateTime @default(now())

  @@index([model, createdAt])
}

/// Action layer поверх сообщений. Сообщение можно превратить в task / decision / follow-up
/// и дальше использовать это уже как сущность выполнения, а не просто как chat history.
///
/// v0.54 detail-drawer: добавлены `priority`, `description`, comments thread
/// (ActionItemComment) и activity log (ActionItemActivity). Поле `title`
/// остаётся коротким (до 160 символов) — markdown body живёт в `description`.
model ActionItem {
  id              String           @id @default(cuid())
  title           String
  /// Markdown description (v0.54). Nullable — старые items не имеют. Max 4000.
  description     String?
  type            ActionItemType
  status          ActionItemStatus @default(OPEN)
  /// v0.54: приоритет для сортировки + визуальной важности.
  priority        ActionItemPriority @default(NORMAL)
  dueAt           DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  serverId        String
  server          Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channelId       String
  channel         Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sourceMessageId String
  sourceMessage   Message          @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User             @relation("ActionItemCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assigneeUserId  String?
  assignee        User?            @relation("ActionItemAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  /// v0.55 approval flow. Default state — NONE (одобрение не требуется).
  /// Когда кто-то делает request approval — переключается в PENDING с
  /// заполненным approverUserId.
  requiresApproval Boolean        @default(false)
  approverUserId   String?
  approver         User?          @relation("ActionItemApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  approvalStatus   ApprovalStatus @default(NONE)
  /// Необязательная текстовая причина approve/reject (например, для reject
  /// объяснение). Frontend показывает в Approval section если задан.
  approvalNote     String?
  /// Timestamp финального approve/reject (null пока PENDING/NONE).
  approvedAt       DateTime?

  /// v0.73 #20 phase 3: escalation. Когда задача overdue 48h+ и ещё открыта,
  /// фоновой scan ставит escalatedAt = now() и эмитит socket-event +
  /// activity-log (ESCALATED). Повторная эскалация — раз в 7 дней (cooldown
  /// в коде, не constraint в схеме).
  escalatedAt      DateTime?

  /// v0.73 #20 phase 4: AI-summary. Краткая 2-3 строчная сводка задачи
  /// (description + recent comments). Генерируется по запросу через
  /// существующую AI-provider chain. NULL = не сгенерирована или
  /// устарела. Frontend в drawer'е показывает блок с кнопкой regenerate.
  aiSummary        String?
  aiSummaryUpdatedAt DateTime?

  comments        ActionItemComment[]
  activities      ActionItemActivity[]
  /// v0.73 #20 phase 2: блокеры — задачи, от которых зависит эта.
  /// `dependencies` = это меня блокирует; `blocks` = я блокирую кого-то.
  dependencies    ActionItemDependency[] @relation("ActionItemBlockedBy")
  blocks          ActionItemDependency[] @relation("ActionItemBlocks")
  /// v0.90 #10 phase 4: rows которые linked к этой задаче (1-to-many).
  /// Cascade при удалении task — rows остаются с actionItemId=null.
  tableRows       TableRow[]

  @@unique([sourceMessageId, type])
  @@index([channelId, status, createdAt])
  @@index([serverId, status, createdAt])
  @@index([assigneeUserId, status])
  @@index([approverUserId, approvalStatus])
}

/// Граф зависимостей между ActionItem'ами (v0.73 #20 phase 2).
/// Self-relation many-to-many через composite PK. `actionItemId` —
/// текущая задача, `dependsOnActionItemId` — её blocker.
///
/// Обе стороны cascade-delete: удалить любую из задач — связь исчезает.
/// Цикл (A→B→A) запрещён на уровне backend — BFS проверка перед insert.
/// Self-loop (A→A) запрещён через runtime check (Postgres CHECK constraint
/// тоже добавлен в миграции для defense-in-depth).
model ActionItemDependency {
  actionItemId          String
  actionItem            ActionItem @relation("ActionItemBlockedBy", fields: [actionItemId], references: [id], onDelete: Cascade)
  dependsOnActionItemId String
  dependsOnActionItem   ActionItem @relation("ActionItemBlocks", fields: [dependsOnActionItemId], references: [id], onDelete: Cascade)
  createdAt             DateTime   @default(now())

  @@id([actionItemId, dependsOnActionItemId])
  @@index([dependsOnActionItemId])
}

/// Comments thread на ActionItem — v0.54 detail drawer.
/// Cascade-delete при удалении item или автора. Edit через editedAt timestamp
/// (нет soft-delete для comment'ов: delete = remove row, отдельное audit-event).
model ActionItemComment {
  id           String     @id @default(cuid())
  actionItemId String
  actionItem   ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  /// v0.63 cascade policy B: nullable + SetNull. Удаление автора не
  /// стирает task discussion — комментарий остаётся анонимным.
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  content      String
  createdAt    DateTime   @default(now())
  /// Время последнего edit (null = не редактировался).
  editedAt     DateTime?

  @@index([actionItemId, createdAt])
  @@index([userId])
}

/// Audit log on ActionItem — v0.54. Каждое значимое изменение (status,
/// assignee, due, priority, title, description) + comments add/delete
/// генерируют запись. История остаётся при удалении actor'а (userId
/// SetNull). Payload — JSON string с before/after значениями.
model ActionItemActivity {
  id           String                 @id @default(cuid())
  actionItemId String
  actionItem   ActionItem             @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  /// Initiator. Null = system / автоматическое событие.
  userId       String?
  user         User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  type         ActionItemActivityType
  /// JSON metadata e.g. `{ "from": "OPEN", "to": "DONE" }` для STATUS_CHANGED.
  /// Frontend парсит per-type — schema-less для гибкости в v1.
  payload      String?
  createdAt    DateTime               @default(now())

  @@index([actionItemId, createdAt])
}

/// Direct conversation — 1-to-1 ИЛИ group (v0.52).
///
/// Two-track membership модель:
///   - **1-to-1 path (legacy):** `userAId`/`userBId` filled, `isGroup=false`.
///     Нормализованная позиция: `userAId < userBId` (string compare). Unique
///     constraint защищает от дубликатов «A→B» и «B→A».
///   - **Group path (v0.52):** `userAId/userBId` NULL, `isGroup=true`,
///     участники в `ConversationParticipant` join-таблице. `name` — user-set
///     title (nullable, frontend генерирует «Pavel, Alex, +2» если null).
///     `createdByUserId` — host (может rename group / add/remove members).
///
/// Membership-check унифицирован через helper `isDmParticipant()` в
/// routes/dm.ts — все routes используют его независимо от типа.
model DirectConversation {
  id            String   @id @default(cuid())
  /// 1-to-1 path: filled. Group path: NULL.
  userAId       String?
  userA         User?    @relation("DMUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId       String?
  userB         User?    @relation("DMUserB", fields: [userBId], references: [id], onDelete: Cascade)
  /// True для group DM (3+ participants). False для legacy 1-to-1.
  isGroup       Boolean  @default(false)
  /// User-set group title. Null = auto-derive из participant names в UI.
  /// Max 80 chars (zod-валидация в route). Не используется для 1-to-1.
  name          String?
  /// Host группы — может rename / add/remove members. Null для legacy 1-to-1
  /// (там обе стороны симметричны). SetNull при удалении user'а — group живёт.
  createdByUserId String?
  createdBy       User?  @relation("DMCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  /// Timestamp последнего сообщения — для сортировки в user's DM list.
  /// Обновляется в transaction при send message.
  lastMessageAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
}

/// Участник group DM. Composite PK (conversationId, userId) гарантирует
/// что один user не может быть в одной group дважды. userId-index для
/// быстрой выборки «все мои conversations» через participant lookup.
model ConversationParticipant {
  conversationId String
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime           @default(now())

  @@id([conversationId, userId])
  @@index([userId])
}

/// AI Memory — последний visit пользователя в канал. Используется для
/// «Since your last visit»: при возвращении в канал спустя >30мин показываем
/// дельту (новые сообщения / actions / pinned / incidents) — операционная
/// сводка «пока тебя не было», без перечитывания всей ленты.
///
/// Composite PK (userId, channelId) — ровно одна запись на пару.
/// onDelete: Cascade чтобы при удалении user/channel записи чистились.
model ChannelLastVisit {
  userId    String
  channelId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  /// Обновляется на каждый явный visit (frontend шлёт POST при открытии канала).
  /// @updatedAt автоматически бампит при db.update; для upsert используем
  /// explicit `new Date()` в route — там видимость явная.
  visitedAt DateTime @default(now())

  @@id([userId, channelId])
  @@index([userId])
}

/// Файл, прикреплённый к сообщению. Multiple attachments per message
/// поддерживается (image grid 2x2 + chips). На soft-delete message
/// attachments тоже скрываются в UI, но row остаётся (для restore-фичи
/// в v1.x если когда-то будет).
/// v0.67: LinkEmbed — кэш OG-preview карточек для URL в чате.
/// Один URL приходит часто (расшариваемые статьи) — не хотим fetch
/// каждый раз. TTL 7 дней через `expiresAt`, очистка lazy (route
/// проверяет expires при чтении). FAILED статусы тоже кэшируются на
/// 24ч, чтобы не долбить bad URL.
enum LinkEmbedStatus {
  OK
  FAILED
}

model LinkEmbed {
  id           String          @id @default(cuid())
  /// Нормализованный URL (lowercased host, removed fragment).
  url          String          @unique
  status       LinkEmbedStatus @default(OK)
  /// OG-meta поля. Все nullable — если preview минимальный, заполняем что есть.
  title        String?
  description  String?
  /// Absolute URL картинки (og:image). Frontend рендерит через стандартный
  /// <img src="..."> без проксирования — это open web, та же модель что
  /// markdown ![]().
  image        String?
  siteName     String?
  fetchedAt    DateTime        @default(now())
  /// Cache TTL. OK=7 дней, FAILED=24 часа. Route проверяет на read.
  expiresAt    DateTime
  /// Текст ошибки для FAILED status. Не отдаём фронту (internal debug).
  error        String?

  @@index([expiresAt])
}

model Attachment {
  id           String   @id @default(cuid())
  messageId    String
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  /// Оригинальное имя файла (для download attribute / chip label).
  filename     String
  /// MIME type — `image/jpeg`, `image/png`, `image/webp`, `application/pdf`, etc.
  mimeType     String
  /// Размер в байтах (после resize для images, original для прочих).
  size         Int
  /// Path на disk-relative URL (`/uploads/attachments/<msgId>-<idx>-<filename>`).
  /// Frontend префиксит BASE_URL.
  url          String
  /// Для images: размеры (для aspect-ratio в lightbox). Null для non-image.
  width        Int?
  height       Int?
  /// Для images > 512px: ресайз 512x512 webp для inline preview. Null если
  /// image сам меньше threshold (тогда url служит и preview, и full).
  thumbnailUrl String?
  /// Порядок в message (0-indexed). UI рендерит по position asc.
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  /// v0.58 voice transcription. Заполняется async после upload audio-файла
  /// через OpenAI Whisper API (если OPENAI_API_KEY сетап). Null = не было
  /// попытки / non-audio / провайдер не сетап.
  transcript        String?
  transcriptStatus  TranscriptStatus @default(NONE)
  /// Текст ошибки если transcriptStatus = FAILED. Отображается в UI как
  /// muted-line под audio player'ом.
  transcriptError   String?
  /// v0.66 audio waveform peaks (Telegram-style visualization).
  /// JSON массив из N=64 normalized чисел 0..100. Считается на frontend
  /// через Web Audio API при upload, передаётся в attachment payload.
  /// Null для non-audio / старых attachments — frontend fallback'нется
  /// на linear progress bar.
  waveformPeaks     Json?
  /// v0.61: если attachment используется как current track в MusicSession.
  /// Inverse relation для cascade лоgic — при удалении attachment Sessoin's
  /// currentTrackAttachmentId уйдёт в NULL (SetNull).
  musicSessions    MusicSession[]

  @@index([messageId])
}

/// Реакция на сообщение. Unique по (messageId, userId, emoji) —
/// один user может поставить только один экземпляр каждого emoji
/// на сообщение. Снятие = DELETE row.
model Reaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Unicode emoji ("👍") или shortcode ("thumbs_up"). Для MVP — short
  /// list разрешённых emoji, валидируется zod-схемой в роуте.
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

/// Operational Table (v0.59 phase 1) — встроенная таблица внутри
/// пространства. Не отдельная Notion-page, а operational surface рядом с
/// каналами (Context Tree). v1 — server-wide; channelId optional для
/// будущего channel-scoped binding (когда таблица «принадлежит» комнате).
///
/// v1 модель — generic key-value cells. Phase 2 добавит relations к
/// ActionItem (rows становятся first-class задачами), AI-fill, formulas.
model Table {
  id              String   @id @default(cuid())
  serverId        String
  server          Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// Optional binding к каналу-источнику. Null = server-wide table.
  channelId       String?
  channel         Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  name            String
  description     String?
  createdByUserId String
  createdBy       User     @relation("TableCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fields          TableField[]
  rows            TableRow[]
  /// v0.75 #10 phase 2.5b: поля других таблиц, ссылающиеся на эту через RELATION.
  /// Inverse relation для SetNull cascade при delete.
  incomingRelations TableField[] @relation("TableFieldRelation")

  @@index([serverId, updatedAt])
  @@index([channelId])
}

model TableField {
  id        String          @id @default(cuid())
  tableId   String
  table     Table           @relation(fields: [tableId], references: [id], onDelete: Cascade)
  name      String
  type      TableFieldType
  /// Для STATUS — JSON-string array допустимых значений `["TODO","DONE"]`.
  /// Null для других типов.
  options   String?
  /// Порядок в строке (0-indexed). UI рендерит по position asc.
  position  Int             @default(0)
  /// v0.75 #10 phase 2.5b RELATION: target table id (same server). SetNull
  /// при удалении target — поле остаётся, UI показывает «таблица удалена».
  /// Только для type=RELATION; для других типов NULL.
  linkedTableId String?
  linkedTable   Table?  @relation("TableFieldRelation", fields: [linkedTableId], references: [id], onDelete: SetNull)

  cells     TableCell[]

  @@index([tableId, position])
  @@index([linkedTableId])
}

model TableRow {
  id        String      @id @default(cuid())
  tableId   String
  table     Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  position  Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  /// v0.90 #10 phase 4: row → ActionItem binding. Если задано — этот row
  /// linked to first-class task. UI отображает status badge, click → drawer.
  /// Phase 4a: read-only binding (создаём task через explicit button, sync
  /// row.cells → action.* нет). Phase 4b: bidirectional sync назначенной
  /// «title» колонки + STATUS column → ActionItem.title/status.
  actionItemId String?
  actionItem   ActionItem? @relation(fields: [actionItemId], references: [id], onDelete: SetNull)

  cells     TableCell[]

  @@index([tableId, position])
  @@index([actionItemId])
}

/// Ячейка: одна на пересечение (rowId, fieldId). Composite PK гарантирует
/// уникальность. Value хранится как plain string; frontend coerces по
/// field.type при render/edit.
model TableCell {
  rowId   String
  row     TableRow   @relation(fields: [rowId], references: [id], onDelete: Cascade)
  fieldId String
  field   TableField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value   String

  @@id([rowId, fieldId])
  @@index([fieldId])
}

/// v0.86 #24 phase 2: статус счёта.
///   DRAFT     — черновик, не виден CLIENT'у
///   SENT      — выставлен, виден CLIENT'у, ждёт оплаты
///   PAID      — оплачен, отображается с зелёной меткой
///   CANCELLED — отменён, виден только OWNER/ADMIN preview
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

/// v0.86 #24 phase 2: client invoices.
///
/// Server-scoped (привязан к CLIENT-mode workspace, но не enforce'нем — invoice
/// можно создать в любом server'е, display gated по mode в frontend).
///
/// Денежные значения в **копейках** (Int) — стандартный pattern для избежания
/// floating-point ошибок. Frontend форматит /100 → display. Currency — ISO
/// code (RUB / USD / EUR / etc), default "RUB".
///
/// Permissions:
///   - OWNER/ADMIN create/edit/delete/status-change.
///   - CLIENT/VIEWER read-only (только SENT + PAID — DRAFT и CANCELLED hidden).
///
/// `number` — human-readable identifier (e.g. "INV-2026-001"), unique per
/// server. Не auto-generated — пользователь сам назначает (или UI suggests).
model Invoice {
  id          String        @id @default(cuid())
  serverId    String
  server      Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  number      String
  title       String
  status      InvoiceStatus @default(DRAFT)
  /// ISO 4217 currency code. UTF-safe ASCII (3 chars).
  currency    String        @default("RUB")
  /// Sum всех line items в копейках. Recomputed на каждый item insert/delete/edit
  /// в transaction. Stored для query-без-join.
  amountTotal Int           @default(0)
  /// Дата выставления (status SENT). Null пока DRAFT.
  issuedAt    DateTime?
  /// Срок оплаты (optional).
  dueAt       DateTime?
  /// Дата оплаты (status PAID).
  paidAt      DateTime?
  /// Free-form notes (markdown). Видны CLIENT'у.
  notes       String?
  /// Автор счёта. Null после удаления user'а (cascade policy B).
  createdByUserId String?
  createdBy   User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items       InvoiceItem[]

  @@unique([serverId, number])
  @@index([serverId, status])
}

/// v0.86 #24 phase 2: line item внутри Invoice.
///
/// Simplified model — нет quantity/unitPrice/tax. Просто title + amount в
/// копейках. Если нужны часы — пользователь напишет "Дизайн логотипа · 12h"
/// в title и подставит сумму. Phase 3 — добавить quantity + unitPrice +
/// VAT, когда станет clear что требуется.
model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  position  Int     @default(0)
  title     String
  /// Сумма в копейках.
  amount    Int

  @@index([invoiceId, position])
}

/// Shared listening room (v0.61). Одна сессия per channel; один член
/// запускает audio-attachment, остальные слышат синхронно.
///
/// Sync: server holds authoritative `startedAt` + `positionMs`. Frontend:
///   position = isPlaying ? (now - startedAt + positionMs) : positionMs
///
/// V1 — без late-join drift correction (REST state at join моментально
/// достаточно для UX). V2 — periodic emit + adaptive seek при drift > 1.5s.
model MusicSession {
  id                       String      @id @default(cuid())
  channelId                String      @unique
  channel                  Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  /// Текущий track (Attachment id). Null = idle / track недоступен.
  currentTrackAttachmentId String?
  currentTrack             Attachment? @relation(fields: [currentTrackAttachmentId], references: [id], onDelete: SetNull)
  /// Когда текущий track начал играть (или resumed). Null когда paused/idle.
  startedAt                DateTime?
  /// Saved position на момент pause. На resume: startedAt = now; position
  /// продолжается от этой точки.
  positionMs               Int         @default(0)
  isPlaying                Boolean     @default(false)
  /// JSON-string array of attachmentIds в очереди (после current).
  queue                    String      @default("[]")
  /// Host — кто запустил. Pause/resume/skip/stop разрешены host'у или
  /// MOD+ (override). Add-to-queue разрешено MEMBER+.
  hostUserId               String
  host                     User        @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
}

/// v1.2.20 — Custom emoji per-server. Server owners + admins загружают
/// изображения и привязывают `:shortcode:` для использования в сообщениях
/// и реакциях. Парсер `:shortcode:` → `<img>` в RichContent на frontend'е
/// смотрит per-server registry.
///
/// Storage: webp 128×128 (sharp resize) в `/uploads/emojis/<serverId>-<id>.webp`.
/// Cascade на server delete → файлы остаются (cleanup отдельным cron'ом,
/// если приоритизируется). Setnull на uploader удалении.
model Emoji {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// Lower-case [a-z0-9_-], 2–30 chars. Unique per server.
  shortcode  String
  /// URL webp-картинки под /uploads/emojis/. После DELETE row файл best-effort
  /// удаляется в backend route.
  url        String
  /// FK на User. SetNull при удалении uploader'а — emoji остаётся в сервере.
  uploaderId String?
  uploader   User?    @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@unique([serverId, shortcode])
  @@index([serverId])
}

/// v1.5.42 Discord-parity A1 — Friendship model.
///
/// Один row на пару пользователей. Пара нормализована (userAId < userBId по
/// строковой компарации cuid'ов) — тот же трюк что у DirectConversation, чтобы
/// `@@unique([userAId, userBId])` ловил обе направления «A→B» и «B→A» одной
/// записью.
///
/// Жизненный цикл:
///   PENDING — requester отправил, addressee не ответил
///     ├─ accept → ACCEPTED (acceptedAt = now)
///     ├─ decline (addressee) / cancel (requester) → row удаляется
///   ACCEPTED — обе стороны друзья
///     └─ unfriend (любая сторона) → row удаляется
///   BLOCKED — одна сторона заблокировала (blockedByUserId филует, какая)
///     └─ unblock (только blocker) → row удаляется (НЕ возврат в ACCEPTED —
///        блок прерывает relationship explicitly)
///
/// Идентификация инициатора:
///   - `requestedByUserId` — кто отправил исходный PENDING (== userAId или userBId)
///   - `blockedByUserId` — кто наложил BLOCKED (NULL для PENDING/ACCEPTED)
///
/// Permission rules (применяются в routes/friends.ts):
///   - POST /api/friends/request: rate-limited (20/15min); auto-accept если
///     mirror PENDING существует; 403 если BLOCKED любой стороной
///   - POST /api/friends/:id/accept: только addressee (тот, кто НЕ requestedByUserId)
///   - DELETE /api/friends/:id: любая сторона friendship может удалить
///   - POST /api/friends/block: создаёт новый BLOCKED row либо transition'ит
///     существующий PENDING/ACCEPTED → BLOCKED; blockedByUserId = me
///   - DELETE /api/friends/block/:userId: только blocker (blockedByUserId == me)
///
/// Cascade: при удалении user'а (любого) cascade-delete его friendships обоих
/// направлений (через userA/userB FK). requestedByUserId / blockedByUserId —
/// SetNull через self-FK (relations "FriendshipRequestedBy"/"FriendshipBlockedBy"),
/// чтобы не блокировать удаление user'а если в payload'е остался pointer.
model Friendship {
  id                String           @id @default(cuid())
  /// Нормализованная пара: userAId < userBId.
  userAId           String
  userA             User             @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId           String
  userB             User             @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  status            FriendshipStatus @default(PENDING)
  /// Кто отправил PENDING (всегда либо userAId либо userBId). Сохраняется
  /// после ACCEPTED как «кто кого добавил» — для аудита и для accept
  /// permission-check (addressee = тот другой).
  requestedByUserId String
  requestedBy       User             @relation("FriendshipRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  /// Заполняется только для BLOCKED status. NULL для PENDING/ACCEPTED.
  blockedByUserId   String?
  blockedBy         User?            @relation("FriendshipBlockedBy", fields: [blockedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  /// Заполняется при transition PENDING → ACCEPTED. NULL для PENDING/BLOCKED.
  acceptedAt        DateTime?

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

