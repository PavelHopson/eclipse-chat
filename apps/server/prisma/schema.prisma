generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl — для prisma migrate (он сам открывает несколько соединений
  // и не любит pgbouncer/pooler). Используется только во время migrate.
  // Для рантайма берётся `url` (= pooled DATABASE_URL).
  // На non-pooled провайдерах (локальный PG, Railway, etc) можно оставить
  // DIRECT_URL пустым в .env — Prisma fallback'нется на url.
  directUrl = env("DIRECT_URL")
}

/// Пользователь — реальный человек. После v0.10 появится Bot, и Member
/// получит поле `type` (HUMAN | BOT) — но пока Member привязан только
/// к User.
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  displayName   String
  /// URL аватара (path-based, обычно `/eclipse-chat/uploads/avatars/<file>`).
  /// nullable — при отсутствии UI рисует placeholder с инициалами.
  avatar        String?
  /// Краткое био пользователя — Twitter-like, max 280 символов
  /// (проверяется на уровне zod-валидации в роуте PATCH /api/users/me/profile).
  bio           String?
  /// Manual presence: ONLINE = default (auto), IDLE/DND/INVISIBLE — user
  /// override. Combines с auto-presence (socket-based) на render:
  /// если manual=INVISIBLE → frontend показывает offline; иначе manual
  /// overrides auto.
  status        UserStatus     @default(ONLINE)
  createdAt     DateTime       @default(now())
  /// 2FA TOTP secret (base32). Зашифрован при-rest через AES-256-GCM
  /// в app-layer (apps/server/src/auth/twoFactor.ts).
  twoFactorSecret      String?
  /// 2FA включён (secret сохранён И первый код подтверждён).
  twoFactorEnabled     Boolean   @default(false)
  /// Recovery codes — JSON массив bcrypt-хэшей. При verify сравниваем bcrypt
  /// и помечаем code как использованный (remove from list).
  twoFactorRecoveryCodes String?
  /// Счётчик неудачных попыток входа. Reset при успехе или после lockoutUntil.
  failedLoginAttempts  Int       @default(0)
  /// Времянка lockout после 5 неудачных попыток. Null = не залочен.
  lockoutUntil         DateTime?

  messages         Message[]
  refreshTokens    RefreshToken[]
  memberships      Member[]
  ownedServers     Server[]              @relation("ServerOwner")
  reactions        Reaction[]
  createdActionItems ActionItem[]        @relation("ActionItemCreator")
  assignedActionItems ActionItem[]       @relation("ActionItemAssignee")
  /// Items на которых я approver (v0.55). Pending → approver_userId = me.
  approvalQueue      ActionItem[]        @relation("ActionItemApprover")
  /// Operational Tables, созданные этим user'ом (v0.59 phase 1).
  createdTables      Table[]             @relation("TableCreator")
  /// Music sessions где user — host (v0.61). Один user может быть host'ом
  /// в нескольких channels одновременно.
  hostedMusicSessions MusicSession[]
  /// Comments написанные этим user'ом на ActionItem'ах (v0.54 drawer).
  actionItemComments ActionItemComment[]
  /// Audit-log записи где user был инициатором (v0.54). Null userId — system.
  actionItemActivities ActionItemActivity[]
  /// DM conversations где user — userA (нормализованная позиция, см. DirectConversation).
  /// Для group DMs userA/userB NULL — membership через ConversationParticipant.
  dmsAsUserA       DirectConversation[]  @relation("DMUserA")
  /// DM conversations где user — userB.
  dmsAsUserB       DirectConversation[]  @relation("DMUserB")
  /// Group DMs, созданные этим user'ом (host). Legacy 1-to-1 имеют createdByUserId=NULL.
  dmGroupsCreated  DirectConversation[]  @relation("DMCreator")
  /// Участие в group DMs (новая модель v0.52). 1-to-1 DMs используют userA/userB,
  /// group DMs — этот join. Membership-check унифицирован в route helper.
  dmParticipations ConversationParticipant[]
  auditLogs        AuditLog[]
  /// Боты которыми владеет user (как создатель).
  ownedBots        Bot[]                 @relation("BotOwner")
  /// Если user — это shadow user для bot'а (1-to-1). null = обычный User.
  botProfile       Bot?                  @relation("BotShadowUser")
  /// Инциденты открытые этим user'ом.
  openedIncidents  Incident[]            @relation("IncidentOpener")
  /// Last-visit per channel (AI Memory «Since your last visit»).
  channelVisits    ChannelLastVisit[]
}

/**
 * Bot — operator entity внутри сервера. main differentiator Eclipse Chat
 * от Discord: bots = first-class citizens с явным API контрактом,
 * не webhooks-only.
 *
 * Архитектурное решение — bot реиспользует существующую User модель как
 * «shadow user»:
 *   - При create Bot — создаётся User row с email `bot-<botId>@eclipse-chat.local`.
 *   - Bot.userId → User.id (1-to-1).
 *   - Messages from bot выглядят как обычные Message с user.id = bot's shadow user.
 *   - Member.userId работает для bot'а как для регулярного юзера (auto-добавляется
 *     в server при create).
 * Это упрощает Message.userId, Reaction, Avatar и т.д. — никакой polymorphism.
 *
 * API auth:
 *   Authorization: Bot ecb_<32-char-base64>
 *   - Сравнение через bcrypt(apiKey, apiKeyHash).
 *   - apiKeyPrefix хранится для quick row-lookup (первые 12 символов).
 */
model Bot {
  id           String   @id @default(cuid())
  name         String
  /// Avatar URL — может быть кастомным или auto-generated.
  avatar       String?
  /// Описание роли бота (для UI), до 280 символов.
  description  String?
  /// Bcrypt hash of API key. Plaintext возвращается одноразово при create/regen.
  apiKeyHash   String
  /// Префикс API key для quick lookup (`ecb_` + 8 chars). Unique для O(1) find.
  apiKeyPrefix String   @unique
  /// Server в котором bot живёт (scoped к одному, как Discord webhooks).
  serverId     String
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// Owner user — может regenerate key и delete bot. Cascade при удалении user'а
  /// удаляет bots — admin должен передать ownership перед уходом из server'а.
  ownerUserId  String
  owner        User     @relation("BotOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  /// Shadow user (1-to-1). Auto-created при bot creation. Bot posts messages
  /// как этот user; reactions, mentions работают штатно.
  userId       String   @unique
  user         User     @relation("BotShadowUser", fields: [userId], references: [id], onDelete: Cascade)
  /// Роль бота — определяет system-prompt template, UI badge и (в будущем)
  /// поведение AI invocation. Default GENERIC = существующие боты не ломаются.
  role         BotRole  @default(GENERIC)
  /// Отвечать на каждое сообщение в TEXT-каналах сервера (без @mention).
  /// Если несколько ботов с autoRespond — отвечает oldest createdAt.
  autoRespond  Boolean  @default(false)
  /// Кастомный system prompt (приоритет над role-template). Max 8000 в API.
  systemPromptOverride String?
  /// JSON array capabilities: ["send_message", "create_action_item", "react"].
  /// Сейчас всё разрешено — но field готов под granular ACL в v0.12.1.
  capabilities String   @default("[\"send_message\",\"react\"]")
  /// HTTPS URL для outbound webhook'ов. Backend POST'ит сюда события
  /// (message.created etc) от каналов где bot — member. Null = нет webhook.
  webhookUrl    String?
  /// Shared secret для HMAC-SHA256 signing webhook payloads. Если задан —
  /// header X-Eclipse-Bot-Signature: sha256=<hex> добавляется на каждый POST.
  webhookSecret String?
  /// JSON массив subscribed events. Default ["message.created"]. Bot
  /// получает только events что в списке.
  webhookEvents String   @default("[\"message.created\"]")
  createdAt    DateTime @default(now())
  /// Когда bot последний раз был использован (любой successful API call).
  lastUsedAt   DateTime?

  @@index([serverId])
  @@index([ownerUserId])
}

/**
 * Audit log: журнал security-events и admin-действий.
 * Никогда не удаляем (compliance). Старше 1 года будут архивироваться
 * cron'ом в отдельную таблицу (v1.x).
 */
enum AuditEventType {
  AUTH_LOGIN
  AUTH_LOGIN_FAILED
  AUTH_LOGIN_LOCKED
  AUTH_LOGOUT
  AUTH_REGISTER
  AUTH_PASSWORD_CHANGE
  TWOFA_ENABLED
  TWOFA_DISABLED
  TWOFA_VERIFIED
  TWOFA_RECOVERY_USED
  SERVER_CREATED
  SERVER_DELETED
  SERVER_BANNER_CHANGED
  SERVER_IDENTITY_CHANGED
  MEMBER_ROLE_CHANGED
  MEMBER_KICKED
  MESSAGE_DELETED_BY_MOD
  CHANNEL_CREATED
  CHANNEL_DELETED
  BOT_CREATED
  BOT_DELETED
  BOT_KEY_REGENERATED
}

model AuditLog {
  id        String         @id @default(cuid())
  type      AuditEventType
  /// User инициатор (может быть null для system events / failed login attempts).
  userId    String?
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// IP origin (для security-расследований). Best-effort, может быть proxy IP.
  ipAddress String?
  /// User-Agent string для browser fingerprint.
  userAgent String?
  /// Дополнительные metadata в JSON (target serverId, что менялось etc).
  /// Никаких PII — только id'шники и status flags.
  metadata  String?
  createdAt DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Роли участников. PostgreSQL поддерживает enum нативно — после v0.6
/// миграции с SQLite на PG используем enum вместо String.
enum MemberRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

/// Тип канала. TEXT — обычный чат. VOICE — голосовой канал (LiveKit).
/// BROADCAST — канал-вещание (news/blogger, Discord×Telegram-гибрид):
/// читают все участники, публикуют только OWNER/ADMIN/MODERATOR.
/// POST messages блокируется для VOICE; для BROADCAST — gated по роли.
enum ChannelType {
  TEXT
  VOICE
  BROADCAST
  /// v0.74 #16 phase 1: execution-комната. Чат заменяется на встроенный
  /// channel-scoped StatusBoard kanban (filter actions по channelId).
  /// Сообщения всё ещё пишутся (вне kanban — могут идти как "обсуждение"),
  /// но primary view — Status Board, не feed.
  EXECUTION
}

/// Manual presence status — user-controlled. ONLINE = default (auto от
/// socket connection). IDLE/DND — user не доступен, но видим как member.
/// INVISIBLE = appears offline для других (но socket connection живой).
enum UserStatus {
  ONLINE
  IDLE
  DND
  INVISIBLE
}

enum ActionItemType {
  TASK
  DECISION
  FOLLOW_UP
}

/// Режим сервера — Client Portal vs Engineering / Internal Ops.
/// CLIENT: мягче UI, скрыты operator-инструменты (Status Board / Execution tab
/// / slash-command hints / BOT badges) — клиент видит calm room, не developer
/// chrome. ENGINEERING (default): полный operator-set.
enum ServerMode {
  ENGINEERING
  CLIENT
}

/// Типология ботов — превращает их из generic shadow-users в embedded
/// role-aware participants. Каждая роль имеет свой system-prompt template
/// (см. ai/botRoles.ts) и собственный визуальный label/colour.
///
///   GENERIC   — default, без специализации (Telegram bridge, мониторинг и т.п.)
///   MODERATOR — channel watchdog: этикет, warning, cleanup-suggestions
///   PM        — project management: задачи / решения / follow-up reminders
///   KNOWLEDGE — server knowledge assistant: Q&A над pinned + history
///   SALES     — outreach / клиентские диалоги (нужно подавать tone)
enum BotRole {
  GENERIC
  MODERATOR
  PM
  KNOWLEDGE
  SALES
  /// v0.74 #18 phase 1: helpdesk-агент. @support / @поддержка mention.
  SUPPORT
  /// v0.74 #18 phase 1: architecture/tech-summaries. @architect / @архитектор.
  ARCHITECT
}

/// Статус инцидента. OPEN = разбор идёт, RESOLVED = закрыт + post-mortem сгенерён.
enum IncidentStatus {
  OPEN
  RESOLVED
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  REVIEW
  DONE
}

/// Приоритет action item. Default NORMAL — backward-compat для existing
/// rows. UI рендерит цветной badge: LOW=idle, NORMAL=text-muted,
/// HIGH=warn, URGENT=risk.
enum ActionItemPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// Audit-log тип события для ActionItemActivity. Расширяется по мере
/// добавления новых mutable полей.
enum ActionItemActivityType {
  CREATED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  DUE_CHANGED
  PRIORITY_CHANGED
  TITLE_CHANGED
  DESCRIPTION_CHANGED
  COMMENT_ADDED
  COMMENT_DELETED
  APPROVAL_REQUESTED
  APPROVAL_APPROVED
  APPROVAL_REJECTED
  DEPENDENCY_ADDED
  DEPENDENCY_REMOVED
  ESCALATED
  AI_SUMMARY_GENERATED
}

/// Статус одобрения action item (v0.55). Отдельный axis от ActionItemStatus —
/// item может быть DONE и не требовать approval, или OPEN и быть APPROVED.
/// Lifecycle: NONE → PENDING → APPROVED / REJECTED. Только approver может
/// перевести из PENDING в финальное состояние.
enum ApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

/// Статус транскрипции аудио-вложения (v0.58). NONE = не запускали (non-audio
/// файл или OPENAI_API_KEY не сетап); PENDING = в работе fire-and-forget;
/// READY = transcript заполнен; FAILED = transcript ошибка (error в
/// transcriptError). UI рендерит status под audio-player.
enum TranscriptStatus {
  NONE
  PENDING
  READY
  FAILED
}

/// Тип поля Operational Table (v0.59 phase 1, расширено v0.62 phase 2).
/// Phase 2 добавил USER (cell.value = userId, UI рендерит avatar/name из
/// member list) и CHECKBOX (cell.value = "true"|"false"). Phase 2.5+ —
/// RELATION (cross-table), FILE (attachment), FORMULA. Coercion value
/// хранится как строка, frontend приводит к нужному типу при render/edit.
enum TableFieldType {
  TEXT
  NUMBER
  STATUS
  DATE
  USER
  CHECKBOX
  /// v0.75 #10 phase 2.5b: ссылка на row(ы) другой таблицы того же сервера.
  /// Cell.value = JSON array of rowIds. Field.linkedTableId — target table.
  RELATION
  /// v0.75 #10 phase 2.5b: файлы в ячейке (upload via /api/tables/:id/upload).
  /// Cell.value = JSON array of `{url, filename, mimeType, size}` objects.
  FILE
}

/// Сервер — контейнер каналов и участников. Создатель автоматически
/// становится Member с role = OWNER.
model Server {
  id          String   @id @default(cuid())
  name        String
  icon        String?
  /// Banner image, 1500×500 webp (resized sharp). Хедер чата + сервер-инфо.
  banner      String?
  /// HSL brand color string без `hsl()` wrapper: "200 80% 60%". Frontend
  /// инжектит `:root { --ec-accent: hsl(X) }` пока активен этот сервер.
  /// Null = default cool sky. Per-server theming без full redesign.
  brandColor  String?
  /// Markdown-описание сервера (до 1000 символов). Показывается в Info modal
  /// и welcome screen для новых членов.
  description String?
  /// Welcome-сообщение для новых members. Показывается один раз в первом
  /// TEXT канале как dismissible system-card. До 500 символов.
  welcomeMessage String?
  /// Режим сервера. ENGINEERING (default) = полный operator-инструментарий.
  /// CLIENT = мягче UI, скрыты Status Board / Execution / slash hints —
  /// для портала клиентов агентств / dev-студий / консалтинга. Меняется
  /// OWNER'ом в Server Settings.
  mode        ServerMode @default(ENGINEERING)
  /// Уникальный код для приёма по ссылке. Регенерируется через PATCH (TODO v0.4+).
  inviteCode  String   @unique @default(cuid())
  /// Владелец — User. Не может быть удалён пока ownsServer (onDelete: Restrict).
  ownerId     String
  owner       User     @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  channels    Channel[]
  members     Member[]
  actionItems ActionItem[]
  bots        Bot[]
  incidents   Incident[]
  tables      Table[]
}

/**
 * Incident — операторский «контур разбора». Создаётся кнопкой «Открыть
 * инцидент»: спавнит dedicated TEXT-канал, собирает timeline (ActionItems
 * + pinned messages), при resolve генерит post-mortem через Ollama.
 *
 * Главный differentiator Eclipse Chat как operator console — связывает
 * уже построенные слои (channels + ActionItems + AI) в incident workflow.
 */
model Incident {
  id             String         @id @default(cuid())
  serverId       String
  server         Server         @relation(fields: [serverId], references: [id], onDelete: Cascade)
  title          String
  status         IncidentStatus @default(OPEN)
  /// Dedicated channel инцидента. SET NULL если канал удалён руками —
  /// Incident-запись остаётся для history. 1-to-1 с Channel.incidentId.
  channelId      String?        @unique
  channel        Channel?       @relation("IncidentChannel", fields: [channelId], references: [id], onDelete: SetNull)
  openedByUserId String
  openedBy       User           @relation("IncidentOpener", fields: [openedByUserId], references: [id], onDelete: Restrict)
  openedAt       DateTime       @default(now())
  resolvedAt     DateTime?
  /// Post-mortem markdown. Генерится Ollama при resolve. Null пока OPEN.
  postMortem     String?

  @@index([serverId, status])
  @@index([channelId])
}

/// Участие пользователя в сервере. Один user — один Member per server.
model Member {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId  String
  server    Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  role      MemberRole @default(MEMBER)
  joinedAt  DateTime   @default(now())

  @@unique([userId, serverId])
}

/// Канал внутри сервера. После миграции на PG поле serverId стало
/// обязательным (NOT NULL) — backfill сделан в v0.4 seed, technical
/// debt из ROADMAP §housekeeping закрыт.
model Channel {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  serverId  String
  server    Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// Тип канала. По умолчанию TEXT — обратная совместимость с v0.4.
  type      ChannelType @default(TEXT)
  /// Позиция в списке каналов сервера (для будущей сортировки UI).
  position  Int         @default(0)
  /// Описание канала (до 1024 символов). Показывается в chat header
  /// под #channel-name + в ChannelSettingsModal. Nullable = нет описания.
  description String?
  /// Кастомный emoji prefix вместо # (TEXT) / 🔊 (VOICE) в UI.
  /// Single emoji char, может быть compound (👨‍💻). Null = default glyph.
  emoji       String?
  /// v0.47 Client Mode v2: internal-канал виден ТОЛЬКО OWNER/ADMIN/MODERATOR
  /// когда Server.mode = CLIENT. В ENGINEERING serverе flag ignored (все
  /// каналы видны всем members). Channel rename/delete не зависят от flag.
  internal    Boolean    @default(false)
  /// v0.74 #29 phase 1: temporary rooms. Если задано — канал авто-удаляется
  /// cron'ом после `expiresAt`. UI показывает countdown badge в chat-header.
  /// NULL = постоянный канал. Hard delete (cascade messages/actions).
  expiresAt   DateTime?
  /// Если канал — incident-канал, ссылка на Incident. Unique (1-to-1).
  /// Null для обычных каналов. UI рисует incident badge если set.
  incidentId  String?    @unique
  incident    Incident?  @relation("IncidentChannel")
  createdAt DateTime    @default(now())

  messages  Message[]
  actionItems ActionItem[]
  visits    ChannelLastVisit[]
  tables    Table[]
  musicSession MusicSession?

  @@index([expiresAt])
}

/// Сообщение. Может принадлежать ЛИБО серверному каналу (`channelId`),
/// ЛИБО direct-conversation (`conversationId`) — XOR-инвариант
/// проверяется на уровне route'ов (Prisma не имеет check constraints).
/// Из двух полей всегда заполнено ровно одно.
model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  /// Время последнего edit'а. Null = не редактировалось.
  editedAt  DateTime?
  /// Soft-delete: deletedAt set → content скрывается, replaced placeholder'ом
  /// в UI. Row остаётся для thread/reply контекста (v0.12).
  deletedAt DateTime?
  /// Pin-bar в chat-header показывает все messages где pinnedAt != null,
  /// sort by pinnedAt desc. Pin/unpin доступен OWNER/ADMIN/MODERATOR.
  /// Для DM messages pin не разрешён (нет ролей в DM).
  pinnedAt  DateTime?
  /// v0.63 cascade policy B: nullable + SetNull. При удалении User
  /// message остаётся, автор=null, UI рендерит «Удалённый пользователь».
  /// Bot deletions / GDPR-style erasure теперь не уничтожают историю.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Канал в server-context. NULL → message принадлежит DM-разговору.
  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  /// DM-разговор. NULL → message принадлежит серверному каналу.
  conversationId String?
  conversation   DirectConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// Thread self-relation: root-сообщения имеют parentMessageId=NULL.
  /// Replies — id root'а. onDelete:SetNull = при удалении root replies остаются
  /// orphan (history preserved, UI рендерит placeholder).
  parentMessageId String?
  parent          Message?  @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  threadReplies   Message[] @relation("MessageThread")
  reactions Reaction[]
  attachments Attachment[]
  actionItems ActionItem[]

  @@index([channelId, pinnedAt])
  @@index([conversationId, createdAt])
  @@index([parentMessageId])
}

/// Action layer поверх сообщений. Сообщение можно превратить в task / decision / follow-up
/// и дальше использовать это уже как сущность выполнения, а не просто как chat history.
///
/// v0.54 detail-drawer: добавлены `priority`, `description`, comments thread
/// (ActionItemComment) и activity log (ActionItemActivity). Поле `title`
/// остаётся коротким (до 160 символов) — markdown body живёт в `description`.
model ActionItem {
  id              String           @id @default(cuid())
  title           String
  /// Markdown description (v0.54). Nullable — старые items не имеют. Max 4000.
  description     String?
  type            ActionItemType
  status          ActionItemStatus @default(OPEN)
  /// v0.54: приоритет для сортировки + визуальной важности.
  priority        ActionItemPriority @default(NORMAL)
  dueAt           DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  serverId        String
  server          Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channelId       String
  channel         Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sourceMessageId String
  sourceMessage   Message          @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User             @relation("ActionItemCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assigneeUserId  String?
  assignee        User?            @relation("ActionItemAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  /// v0.55 approval flow. Default state — NONE (одобрение не требуется).
  /// Когда кто-то делает request approval — переключается в PENDING с
  /// заполненным approverUserId.
  requiresApproval Boolean        @default(false)
  approverUserId   String?
  approver         User?          @relation("ActionItemApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  approvalStatus   ApprovalStatus @default(NONE)
  /// Необязательная текстовая причина approve/reject (например, для reject
  /// объяснение). Frontend показывает в Approval section если задан.
  approvalNote     String?
  /// Timestamp финального approve/reject (null пока PENDING/NONE).
  approvedAt       DateTime?

  /// v0.73 #20 phase 3: escalation. Когда задача overdue 48h+ и ещё открыта,
  /// фоновой scan ставит escalatedAt = now() и эмитит socket-event +
  /// activity-log (ESCALATED). Повторная эскалация — раз в 7 дней (cooldown
  /// в коде, не constraint в схеме).
  escalatedAt      DateTime?

  /// v0.73 #20 phase 4: AI-summary. Краткая 2-3 строчная сводка задачи
  /// (description + recent comments). Генерируется по запросу через
  /// существующую AI-provider chain. NULL = не сгенерирована или
  /// устарела. Frontend в drawer'е показывает блок с кнопкой regenerate.
  aiSummary        String?
  aiSummaryUpdatedAt DateTime?

  comments        ActionItemComment[]
  activities      ActionItemActivity[]
  /// v0.73 #20 phase 2: блокеры — задачи, от которых зависит эта.
  /// `dependencies` = это меня блокирует; `blocks` = я блокирую кого-то.
  dependencies    ActionItemDependency[] @relation("ActionItemBlockedBy")
  blocks          ActionItemDependency[] @relation("ActionItemBlocks")

  @@unique([sourceMessageId, type])
  @@index([channelId, status, createdAt])
  @@index([serverId, status, createdAt])
  @@index([assigneeUserId, status])
  @@index([approverUserId, approvalStatus])
}

/// Граф зависимостей между ActionItem'ами (v0.73 #20 phase 2).
/// Self-relation many-to-many через composite PK. `actionItemId` —
/// текущая задача, `dependsOnActionItemId` — её blocker.
///
/// Обе стороны cascade-delete: удалить любую из задач — связь исчезает.
/// Цикл (A→B→A) запрещён на уровне backend — BFS проверка перед insert.
/// Self-loop (A→A) запрещён через runtime check (Postgres CHECK constraint
/// тоже добавлен в миграции для defense-in-depth).
model ActionItemDependency {
  actionItemId          String
  actionItem            ActionItem @relation("ActionItemBlockedBy", fields: [actionItemId], references: [id], onDelete: Cascade)
  dependsOnActionItemId String
  dependsOnActionItem   ActionItem @relation("ActionItemBlocks", fields: [dependsOnActionItemId], references: [id], onDelete: Cascade)
  createdAt             DateTime   @default(now())

  @@id([actionItemId, dependsOnActionItemId])
  @@index([dependsOnActionItemId])
}

/// Comments thread на ActionItem — v0.54 detail drawer.
/// Cascade-delete при удалении item или автора. Edit через editedAt timestamp
/// (нет soft-delete для comment'ов: delete = remove row, отдельное audit-event).
model ActionItemComment {
  id           String     @id @default(cuid())
  actionItemId String
  actionItem   ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  /// v0.63 cascade policy B: nullable + SetNull. Удаление автора не
  /// стирает task discussion — комментарий остаётся анонимным.
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  content      String
  createdAt    DateTime   @default(now())
  /// Время последнего edit (null = не редактировался).
  editedAt     DateTime?

  @@index([actionItemId, createdAt])
  @@index([userId])
}

/// Audit log on ActionItem — v0.54. Каждое значимое изменение (status,
/// assignee, due, priority, title, description) + comments add/delete
/// генерируют запись. История остаётся при удалении actor'а (userId
/// SetNull). Payload — JSON string с before/after значениями.
model ActionItemActivity {
  id           String                 @id @default(cuid())
  actionItemId String
  actionItem   ActionItem             @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  /// Initiator. Null = system / автоматическое событие.
  userId       String?
  user         User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  type         ActionItemActivityType
  /// JSON metadata e.g. `{ "from": "OPEN", "to": "DONE" }` для STATUS_CHANGED.
  /// Frontend парсит per-type — schema-less для гибкости в v1.
  payload      String?
  createdAt    DateTime               @default(now())

  @@index([actionItemId, createdAt])
}

/// Direct conversation — 1-to-1 ИЛИ group (v0.52).
///
/// Two-track membership модель:
///   - **1-to-1 path (legacy):** `userAId`/`userBId` filled, `isGroup=false`.
///     Нормализованная позиция: `userAId < userBId` (string compare). Unique
///     constraint защищает от дубликатов «A→B» и «B→A».
///   - **Group path (v0.52):** `userAId/userBId` NULL, `isGroup=true`,
///     участники в `ConversationParticipant` join-таблице. `name` — user-set
///     title (nullable, frontend генерирует «Pavel, Alex, +2» если null).
///     `createdByUserId` — host (может rename group / add/remove members).
///
/// Membership-check унифицирован через helper `isDmParticipant()` в
/// routes/dm.ts — все routes используют его независимо от типа.
model DirectConversation {
  id            String   @id @default(cuid())
  /// 1-to-1 path: filled. Group path: NULL.
  userAId       String?
  userA         User?    @relation("DMUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId       String?
  userB         User?    @relation("DMUserB", fields: [userBId], references: [id], onDelete: Cascade)
  /// True для group DM (3+ participants). False для legacy 1-to-1.
  isGroup       Boolean  @default(false)
  /// User-set group title. Null = auto-derive из participant names в UI.
  /// Max 80 chars (zod-валидация в route). Не используется для 1-to-1.
  name          String?
  /// Host группы — может rename / add/remove members. Null для legacy 1-to-1
  /// (там обе стороны симметричны). SetNull при удалении user'а — group живёт.
  createdByUserId String?
  createdBy       User?  @relation("DMCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  /// Timestamp последнего сообщения — для сортировки в user's DM list.
  /// Обновляется в transaction при send message.
  lastMessageAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
}

/// Участник group DM. Composite PK (conversationId, userId) гарантирует
/// что один user не может быть в одной group дважды. userId-index для
/// быстрой выборки «все мои conversations» через participant lookup.
model ConversationParticipant {
  conversationId String
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime           @default(now())

  @@id([conversationId, userId])
  @@index([userId])
}

/// AI Memory — последний visit пользователя в канал. Используется для
/// «Since your last visit»: при возвращении в канал спустя >30мин показываем
/// дельту (новые сообщения / actions / pinned / incidents) — операционная
/// сводка «пока тебя не было», без перечитывания всей ленты.
///
/// Composite PK (userId, channelId) — ровно одна запись на пару.
/// onDelete: Cascade чтобы при удалении user/channel записи чистились.
model ChannelLastVisit {
  userId    String
  channelId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  /// Обновляется на каждый явный visit (frontend шлёт POST при открытии канала).
  /// @updatedAt автоматически бампит при db.update; для upsert используем
  /// explicit `new Date()` в route — там видимость явная.
  visitedAt DateTime @default(now())

  @@id([userId, channelId])
  @@index([userId])
}

/// Файл, прикреплённый к сообщению. Multiple attachments per message
/// поддерживается (image grid 2x2 + chips). На soft-delete message
/// attachments тоже скрываются в UI, но row остаётся (для restore-фичи
/// в v1.x если когда-то будет).
/// v0.67: LinkEmbed — кэш OG-preview карточек для URL в чате.
/// Один URL приходит часто (расшариваемые статьи) — не хотим fetch
/// каждый раз. TTL 7 дней через `expiresAt`, очистка lazy (route
/// проверяет expires при чтении). FAILED статусы тоже кэшируются на
/// 24ч, чтобы не долбить bad URL.
enum LinkEmbedStatus {
  OK
  FAILED
}

model LinkEmbed {
  id           String          @id @default(cuid())
  /// Нормализованный URL (lowercased host, removed fragment).
  url          String          @unique
  status       LinkEmbedStatus @default(OK)
  /// OG-meta поля. Все nullable — если preview минимальный, заполняем что есть.
  title        String?
  description  String?
  /// Absolute URL картинки (og:image). Frontend рендерит через стандартный
  /// <img src="..."> без проксирования — это open web, та же модель что
  /// markdown ![]().
  image        String?
  siteName     String?
  fetchedAt    DateTime        @default(now())
  /// Cache TTL. OK=7 дней, FAILED=24 часа. Route проверяет на read.
  expiresAt    DateTime
  /// Текст ошибки для FAILED status. Не отдаём фронту (internal debug).
  error        String?

  @@index([expiresAt])
}

model Attachment {
  id           String   @id @default(cuid())
  messageId    String
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  /// Оригинальное имя файла (для download attribute / chip label).
  filename     String
  /// MIME type — `image/jpeg`, `image/png`, `image/webp`, `application/pdf`, etc.
  mimeType     String
  /// Размер в байтах (после resize для images, original для прочих).
  size         Int
  /// Path на disk-relative URL (`/uploads/attachments/<msgId>-<idx>-<filename>`).
  /// Frontend префиксит BASE_URL.
  url          String
  /// Для images: размеры (для aspect-ratio в lightbox). Null для non-image.
  width        Int?
  height       Int?
  /// Для images > 512px: ресайз 512x512 webp для inline preview. Null если
  /// image сам меньше threshold (тогда url служит и preview, и full).
  thumbnailUrl String?
  /// Порядок в message (0-indexed). UI рендерит по position asc.
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  /// v0.58 voice transcription. Заполняется async после upload audio-файла
  /// через OpenAI Whisper API (если OPENAI_API_KEY сетап). Null = не было
  /// попытки / non-audio / провайдер не сетап.
  transcript        String?
  transcriptStatus  TranscriptStatus @default(NONE)
  /// Текст ошибки если transcriptStatus = FAILED. Отображается в UI как
  /// muted-line под audio player'ом.
  transcriptError   String?
  /// v0.66 audio waveform peaks (Telegram-style visualization).
  /// JSON массив из N=64 normalized чисел 0..100. Считается на frontend
  /// через Web Audio API при upload, передаётся в attachment payload.
  /// Null для non-audio / старых attachments — frontend fallback'нется
  /// на linear progress bar.
  waveformPeaks     Json?
  /// v0.61: если attachment используется как current track в MusicSession.
  /// Inverse relation для cascade лоgic — при удалении attachment Sessoin's
  /// currentTrackAttachmentId уйдёт в NULL (SetNull).
  musicSessions    MusicSession[]

  @@index([messageId])
}

/// Реакция на сообщение. Unique по (messageId, userId, emoji) —
/// один user может поставить только один экземпляр каждого emoji
/// на сообщение. Снятие = DELETE row.
model Reaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Unicode emoji ("👍") или shortcode ("thumbs_up"). Для MVP — short
  /// list разрешённых emoji, валидируется zod-схемой в роуте.
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

/// Operational Table (v0.59 phase 1) — встроенная таблица внутри
/// пространства. Не отдельная Notion-page, а operational surface рядом с
/// каналами (Context Tree). v1 — server-wide; channelId optional для
/// будущего channel-scoped binding (когда таблица «принадлежит» комнате).
///
/// v1 модель — generic key-value cells. Phase 2 добавит relations к
/// ActionItem (rows становятся first-class задачами), AI-fill, formulas.
model Table {
  id              String   @id @default(cuid())
  serverId        String
  server          Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// Optional binding к каналу-источнику. Null = server-wide table.
  channelId       String?
  channel         Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  name            String
  description     String?
  createdByUserId String
  createdBy       User     @relation("TableCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fields          TableField[]
  rows            TableRow[]
  /// v0.75 #10 phase 2.5b: поля других таблиц, ссылающиеся на эту через RELATION.
  /// Inverse relation для SetNull cascade при delete.
  incomingRelations TableField[] @relation("TableFieldRelation")

  @@index([serverId, updatedAt])
  @@index([channelId])
}

model TableField {
  id        String          @id @default(cuid())
  tableId   String
  table     Table           @relation(fields: [tableId], references: [id], onDelete: Cascade)
  name      String
  type      TableFieldType
  /// Для STATUS — JSON-string array допустимых значений `["TODO","DONE"]`.
  /// Null для других типов.
  options   String?
  /// Порядок в строке (0-indexed). UI рендерит по position asc.
  position  Int             @default(0)
  /// v0.75 #10 phase 2.5b RELATION: target table id (same server). SetNull
  /// при удалении target — поле остаётся, UI показывает «таблица удалена».
  /// Только для type=RELATION; для других типов NULL.
  linkedTableId String?
  linkedTable   Table?  @relation("TableFieldRelation", fields: [linkedTableId], references: [id], onDelete: SetNull)

  cells     TableCell[]

  @@index([tableId, position])
  @@index([linkedTableId])
}

model TableRow {
  id        String      @id @default(cuid())
  tableId   String
  table     Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  position  Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  cells     TableCell[]

  @@index([tableId, position])
}

/// Ячейка: одна на пересечение (rowId, fieldId). Composite PK гарантирует
/// уникальность. Value хранится как plain string; frontend coerces по
/// field.type при render/edit.
model TableCell {
  rowId   String
  row     TableRow   @relation(fields: [rowId], references: [id], onDelete: Cascade)
  fieldId String
  field   TableField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value   String

  @@id([rowId, fieldId])
  @@index([fieldId])
}

/// Shared listening room (v0.61). Одна сессия per channel; один член
/// запускает audio-attachment, остальные слышат синхронно.
///
/// Sync: server holds authoritative `startedAt` + `positionMs`. Frontend:
///   position = isPlaying ? (now - startedAt + positionMs) : positionMs
///
/// V1 — без late-join drift correction (REST state at join моментально
/// достаточно для UX). V2 — periodic emit + adaptive seek при drift > 1.5s.
model MusicSession {
  id                       String      @id @default(cuid())
  channelId                String      @unique
  channel                  Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  /// Текущий track (Attachment id). Null = idle / track недоступен.
  currentTrackAttachmentId String?
  currentTrack             Attachment? @relation(fields: [currentTrackAttachmentId], references: [id], onDelete: SetNull)
  /// Когда текущий track начал играть (или resumed). Null когда paused/idle.
  startedAt                DateTime?
  /// Saved position на момент pause. На resume: startedAt = now; position
  /// продолжается от этой точки.
  positionMs               Int         @default(0)
  isPlaying                Boolean     @default(false)
  /// JSON-string array of attachmentIds в очереди (после current).
  queue                    String      @default("[]")
  /// Host — кто запустил. Pause/resume/skip/stop разрешены host'у или
  /// MOD+ (override). Add-to-queue разрешено MEMBER+.
  hostUserId               String
  host                     User        @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
}
