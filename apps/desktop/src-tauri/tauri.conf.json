{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eclipse Chat",
  "version": "1.0.5",
  "identifier": "ru.star-crm.eclipse-chat",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "https://app.star-crm.ru/eclipse-chat/",
    "frontendDist": "https://app.star-crm.ru/eclipse-chat/"
  },
  "app": {
    "windows": [
      {
        "title": "Eclipse Chat",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 Eclipse Forge. Eclipse Chat.",
    "category": "Productivity",
    "publisher": "Eclipse Forge",
    "homepage": "https://app.star-crm.ru/eclipse-chat/",
    "shortDescription": "Self-hosted operational chat для AI-first команд",
    "longDescription": "Eclipse Chat — operational communication infrastructure: чат, голос, задачи, решения, операционная память в одном calm пространстве. Self-hosted, без внешних зависимостей.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "compression": "lzma",
        "displayLanguageSelector": true,
        "languages": ["Russian", "English"],
        "sidebarImage": "./windows/branding/nsis-sidebar.bmp",
        "headerImage": "./windows/branding/nsis-header.bmp",
        "installerIcon": "./icons/icon.ico",
        "uninstallerIcon": "./icons/icon.ico",
        "installMode": "currentUser",
        "startMenuFolder": "Eclipse Forge"
      },
      "wix": {
        "language": ["ru-RU", "en-US"],
        "bannerPath": "./windows/branding/wix-banner.bmp",
        "dialogImagePath": "./windows/branding/wix-dialog.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/PavelHopson/eclipse-chat/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFEOTk5QzMzRDg2QkJCNDkKUldSSnUydllNNXlaSFVWUVZ4aTJrNDFQK1UyQVhEa1d4dmRjVXM3Wko3dnV1aU9xMXJuRnhJYmYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
