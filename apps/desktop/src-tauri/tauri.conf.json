{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eclipse Chat",
  "version": "1.0.3",
  "identifier": "ru.star-crm.eclipse-chat",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "https://app.star-crm.ru/eclipse-chat/",
    "frontendDist": "https://app.star-crm.ru/eclipse-chat/"
  },
  "app": {
    "windows": [
      {
        "title": "Eclipse Chat",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 Star CRM. Eclipse Chat.",
    "category": "Productivity",
    "shortDescription": "Self-hosted operational chat для AI-first команд",
    "longDescription": "Eclipse Chat — operational communication infrastructure: чат, голос, задачи, решения, операционная память в одном calm пространстве. Self-hosted, без внешних зависимостей."
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/PavelHopson/eclipse-chat/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_AFTER_RUNNING__npm_run_tauri_signer_generate__SEE_README"
    }
  }
}
