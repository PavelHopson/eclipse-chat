# Eclipse Chat — Environment Variables
# Скопируй в .env и замени значения

# Домен (для production)
DOMAIN=chat.example.com

# JWT
JWT_ACCESS_SECRET=change-me-32-chars-random-string
JWT_REFRESH_SECRET=change-me-another-32-chars-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=eclipse
POSTGRES_PASSWORD=change-me
POSTGRES_DB=eclipse_chat
DATABASE_URL=postgresql://eclipse:change-me@localhost:5432/eclipse_chat

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# MinIO (S3-совместимое хранилище файлов)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=eclipse
MINIO_ROOT_PASSWORD=change-me-min-8-chars
MINIO_BUCKET=eclipse-chat
MINIO_USE_SSL=false

# App
NODE_ENV=development
PORT=3000
MAX_FILE_SIZE_MB=25
CORS_ORIGIN=http://localhost:5173

# AI / @ai агент
# v1.6.61 — @ai работает ИЗ КОРОБКИ через keyless-Pollinations (см. ниже), ключи
# не обязательны. Любой заданный ключ просто повышает качество/скорость/надёжность.
# Цепочка авто-фолбэка: Ollama -> Groq -> Cerebras -> OpenRouter -> NVIDIA -> Mistral -> YandexGPT -> OpenAI -> Pollinations
# Self-host (free, privacy):
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:7b
# Облачные бесплатные (быстрые):
# GROQ_API_KEY=gsk_...            # console.groq.com
# CEREBRAS_API_KEY=csk-...        # cloud.cerebras.ai
# OPENROUTER_API_KEY=...          # openrouter.ai (free DeepSeek/Qwen/Llama)
# NVIDIA_API_KEY=nvapi-...        # build.nvidia.com (95 free)
# MISTRAL_API_KEY=...             # console.mistral.ai
# РФ free-tier (приватный, доступен из РФ — Yandex Cloud Foundation Models):
# YANDEX_API_KEY=...              # ключ сервисного аккаунта (console.cloud.yandex.ru)
# YANDEX_FOLDER_ID=...            # каталог Cloud (оба обязательны)
# YANDEX_MODEL=yandexgpt-lite/latest   # короткое имя авто-оборачивается в gpt://<folder>/...
# Дешёвые облачные (cheap paid, OpenAI-compatible) — ⚠️ сторонние/КНР-провайдеры,
# @ai-контент уходит к ним, НЕ для чувствительных данных; после free, перед paid:
# DEEPSEEK_API_KEY=...            # platform.deepseek.com (DEEPSEEK_MODEL=deepseek-chat)
# GLM_API_KEY=...                 # z.ai / BigModel standard API (GLM_MODEL=glm-4.6; НЕ Coding Plan)
# MIMO_API_KEY=...                # platform.xiaomimimo.com (MIMO_MODEL=mimo-v2.5-pro)
# Custom OpenAI-compatible (generic slot, напр. OpenModel-промо; нужны оба):
# CUSTOM_LLM_BASE_URL=...         # base без /chat/completions
# CUSTOM_LLM_API_KEY=...          # CUSTOM_LLM_MODEL=<model>
# Paid fallback:
# OPENAI_API_KEY=...
# AI_TIMEOUT_MS=60000
# Keyless free fallback (ВКЛЮЧЁН по умолчанию, регистрация не нужна; стоит последним).
# Контент @ai уходит на публичный сервис Pollinations (private:true → не в публичную
# ленту). Best-effort: анонимный tier rate-limited. Для полной приватности — Ollama.
# POLLINATIONS_DISABLED=1          # выключить keyless-fallback
# POLLINATIONS_MODELS=openai       # CSV chain, напр. openai,openai-fast,mistral
# POLLINATIONS_REFERRER=eclipse-chat
